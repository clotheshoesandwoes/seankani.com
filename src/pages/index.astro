    ctx.fillStyle=sr;ctx.fillRect(sunX-12,waterStart,24,25);

    // ── Jet skis with foam wakes ──
    for(const js of socalJetSkis){
      js.x+=js.vx; js.bob+=.08;
      if(js.x>W2+30)js.x=-30; if(js.x<-30)js.x=W2+30;
      const jy=js.y+Math.sin(js.bob)*1.2;
      const dir=js.vx>0?1:-1;
      // Wake — fanning foam trail
      for(let wi=0;wi<8;wi++){
        const wx=js.x-dir*(wi*4+4);
        const wy=jy+wi*.4;
        const wsz=2+wi*.3;
        ctx.fillStyle=`rgba(255,255,255,${.25-wi*.025})`;
        ctx.beginPath();ctx.arc(wx,wy,wsz,0,6.28);ctx.fill();
      }
