        ctx.beginPath();ctx.arc(js.x+dir*(7+s*1.5),jy-1-s,1,0,6.28);ctx.fill();
      }
    }

    // ── Surfers riding swells ──
    for(const sf of socalSurfers){
      sf.phase+=.04;
      const wave=Math.sin(sf.phase)*4;
      const sx=sf.x+Math.sin(sf.phase*.3)*15;
      const sy=sf.y+wave;
      // Wave swell line under surfer
      ctx.strokeStyle='rgba(255,255,255,.35)';ctx.lineWidth=1.2;
      ctx.beginPath();
      for(let dx=-14;dx<=14;dx+=2){
        const wy2=sy+2-Math.cos(dx*.18)*1.5;
        dx===-14?ctx.moveTo(sx+dx,wy2):ctx.lineTo(sx+dx,wy2);
      }
      ctx.stroke();
      // Board
      ctx.fillStyle=`rgba(${sf.c[0]},${sf.c[1]},${sf.c[2]},.7)`;
      ctx.beginPath();ctx.ellipse(sx,sy,8,1.5,0,0,6.28);ctx.fill();
      // Surfer body
      ctx.fillStyle='rgba(40,28,18,.65)';
      ctx.fillRect(sx-1,sy-6,2,5);
      // Arms out for balance
      ctx.strokeStyle='rgba(40,28,18,.55)';ctx.lineWidth=1;
      ctx.beginPath();ctx.moveTo(sx-1,sy-4);ctx.lineTo(sx-4,sy-3);ctx.stroke();
      ctx.beginPath();ctx.moveTo(sx+1,sy-4);ctx.lineTo(sx+4,sy-2);ctx.stroke();
      // Head
      ctx.fillStyle='rgba(40,28,18,.7)';
      ctx.beginPath();ctx.arc(sx,sy-7,1.5,0,6.28);ctx.fill();
    }

    // ── Paraglider drifting over the bluffs ──
    if(socalParaglider){
      const pg=socalParaglider;
      pg.x+=pg.vx; pg.phase+=.01;
      if(pg.x>W2+50)pg.x=-50;
      const pgy=pg.y+Math.sin(pg.phase)*8;
      // Canopy — half-ellipse rainbow stripes
      const stripes=[[255,80,80],[255,180,40],[255,240,80],[80,200,120],[80,150,255]];
      const cw=22, ch=8;
      for(let si=0;si<stripes.length;si++){
        const sc=stripes[si];
        const segW=cw*2/stripes.length;
        ctx.fillStyle=`rgba(${sc[0]},${sc[1]},${sc[2]},.6)`;
        ctx.beginPath();
        ctx.moveTo(pg.x-cw+si*segW,pgy);
        ctx.quadraticCurveTo(pg.x-cw+si*segW+segW/2,pgy-ch,pg.x-cw+(si+1)*segW,pgy);
        ctx.lineTo(pg.x-cw+(si+1)*segW,pgy+1);
        ctx.lineTo(pg.x-cw+si*segW,pgy+1);
        ctx.closePath();ctx.fill();
      }
      // Lines
      ctx.strokeStyle='rgba(60,60,60,.35)';ctx.lineWidth=.5;
      for(let li=-1;li<=1;li++){
        ctx.beginPath();ctx.moveTo(pg.x+li*8,pgy+1);ctx.lineTo(pg.x,pgy+12);ctx.stroke();
      }
      // Pilot
      ctx.fillStyle='rgba(40,30,20,.7)';
      ctx.beginPath();ctx.arc(pg.x,pgy+13,2,0,6.28);ctx.fill();
      ctx.fillRect(pg.x-1,pgy+12,2,4);
    }

    // ── Banner plane (classic SoCal beach) ──
    if(socalBannerPlane){
      const bp=socalBannerPlane;
      bp.x+=bp.vx;
      if(bp.x>W2+400)bp.x=-400;
      const bx=bp.x, by=bp.y;
      // Plane body
      ctx.fillStyle='rgba(220,80,40,.85)';
      ctx.beginPath();ctx.ellipse(bx,by,9,2.5,0,0,6.28);ctx.fill();
      // Wing
      ctx.fillStyle='rgba(200,70,35,.75)';
      ctx.fillRect(bx-3,by-1,6,4.5);
      // Tail
      ctx.beginPath();ctx.moveTo(bx-9,by);ctx.lineTo(bx-12,by-4);ctx.lineTo(bx-9,by);ctx.fill();
      // Propeller blur
      ctx.strokeStyle='rgba(200,200,200,.4)';ctx.lineWidth=.6;
      ctx.beginPath();ctx.moveTo(bx+9,by-3);ctx.lineTo(bx+9,by+3);ctx.stroke();
      // Tow rope
      ctx.strokeStyle='rgba(80,60,40,.4)';ctx.lineWidth=.5;
      ctx.beginPath();ctx.moveTo(bx-12,by);ctx.lineTo(bx-30,by+1);ctx.stroke();
      // Banner — fluttering
      const bannerStartX=bx-30, bannerW=180;
      const bannerH=14;
      ctx.fillStyle='rgba(255,255,255,.85)';
      ctx.beginPath();
      ctx.moveTo(bannerStartX,by-bannerH/2);
      for(let bxp=0;bxp<=bannerW;bxp+=8){
        const flutter=Math.sin(bxp*.05+now*.005)*1.5;
        ctx.lineTo(bannerStartX-bxp,by-bannerH/2+flutter);
      }
      for(let bxp=bannerW;bxp>=0;bxp-=8){
        const flutter=Math.sin(bxp*.05+now*.005)*1.5;
        ctx.lineTo(bannerStartX-bxp,by+bannerH/2+flutter);
      }
      ctx.closePath();ctx.fill();
      // Banner outline
      ctx.strokeStyle='rgba(180,40,40,.5)';ctx.lineWidth=.5;ctx.stroke();
      // Banner text
      ctx.save();
      ctx.font=`bold 9px Inter,sans-serif`;
      ctx.fillStyle='rgba(200,40,40,.95)';
      ctx.textAlign='center';
      const flutterMid=Math.sin(bannerW*.025+now*.005)*1.5;
      ctx.fillText(bp.bannerText, bannerStartX-bannerW/2, by+3+flutterMid);
      ctx.restore();
    }

    // ── Auto dolphin jumps (random, not just on cursor) ──
    if(now>socalNextAutoDolphin){
      socalDolphins.push({
        x:W2*.15+Math.random()*W2*.7,
        y:waterStart+10+Math.random()*20,
        t:now,vx:(Math.random()-.5)*1.5
      });
      // Sometimes a pod (multiple)
      if(Math.random()>.6){
        for(let i=1;i<=2;i++){
          socalDolphins.push({
            x:W2*.15+Math.random()*W2*.7,
            y:waterStart+10+Math.random()*20,
            t:now+i*200,vx:(Math.random()-.5)*1.5
          });
        }
      }
      socalNextAutoDolphin=now+5000+Math.random()*8000;
    }

    // Cursor (water only)
    if(sMs.x>-1e3){
      if(sMs.y>waterStart&&Math.random()>.85) socalRipples.push({x:sMs.x,y:sMs.y,t:now});
      if(sMs.y>waterStart&&Math.random()>.995) socalDolphins.push({x:sMs.x,y:sMs.y,t:now,vx:(Math.random()-.5)*1.5});
    }
  }
  // ── Toggle handler ──
  const toggleBtn=document.querySelector('.theme-toggle');
  let socalFrame=null;
  function startSocal(){genSocal();function loop(n){if(!isDark){drawSocal(n);socalFrame=requestAnimationFrame(loop);}}socalFrame=requestAnimationFrame(loop);}

  if(toggleBtn){
    toggleBtn.addEventListener('click',()=>{
      isDark=!isDark;
      document.documentElement.classList.toggle('light',!isDark);
      if(isDark){if(socalFrame)cancelAnimationFrame(socalFrame);cv2.getContext('2d').clearRect(0,0,cv2.width,cv2.height);}
      else startSocal();
      // Immediately update role color for new theme
      if(re){const nr=getRoles();const r=nr[ci%nr.length];re.style.color=r.c;re.style.textShadow=r.g;}
    });
  }

  // Track mouse for SoCal interactions
  document.addEventListener('mousemove',(e)=>{if(!isDark){sMs.x=e.clientX;sMs.y=e.clientY;}});
  document.addEventListener('mouseleave',()=>{sMs.x=-9e3;sMs.y=-9e3;});
  document.addEventListener('touchmove',(e)=>{if(!isDark&&e.touches.length===1){sMs.x=e.touches[0].clientX;sMs.y=e.touches[0].clientY;}},{passive:true});
  document.addEventListener('touchend',()=>{sMs.x=-9e3;sMs.y=-9e3;},{passive:true});
  // ═══════ DESKTOP INTERACTIONS ═══════
  if (window.matchMedia('(pointer:fine)').matches) {
    const sp = document.querySelector('.spotlight');
    if (sp) document.addEventListener('mousemove', (e) => {
      sp.style.background = `radial-gradient(600px circle at ${e.clientX}px ${e.clientY}px,rgba(255,255,255,.03),transparent 40%)`;
    });
    const ct = document.querySelector('.cta');
    if (ct) {
      ct.addEventListener('mousemove', (e) => {
        const r = ct.getBoundingClientRect();
        ct.style.transform = `translate(${(e.clientX-r.left-r.width/2)*.25}px,${(e.clientY-r.top-r.height/2)*.25}px)`;
      });
      ct.addEventListener('mouseleave', () => { ct.style.transform = ''; });
    }
  }

  // ═══════ TEXT SCRAMBLE ═══════
  function scr(el, tx, dur) {
    const ch = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789';
    const t0 = performance.now();
    (function go(n) {
      const p = Math.min((n - t0) / dur, 1); let s = '';
      for (let i = 0; i < tx.length; i++) s += (tx[i]===' '||tx[i]==='.') ? tx[i] : i < p * tx.length ? tx[i] : ch[~~(Math.random()*ch.length)];
      el.textContent = s;
      if (p < 1) requestAnimationFrame(go);
    })(performance.now());
  }
  const tg = document.querySelector('.tagline');
  if (tg) setTimeout(() => scr(tg, 'Builder of things.', 1200), 650);

  // ═══════ CONTACT FORM ═══════
  const fm = document.querySelector('.contact-form');
  if (fm) {
    fm.addEventListener('submit', (e) => {
      e.preventDefault();
      const name = fm.querySelector('[name="name"]').value.trim();
      const email = fm.querySelector('[name="email"]').value.trim();
      const message = fm.querySelector('[name="message"]').value.trim();
      const subject = encodeURIComponent(`New inquiry from ${name}`);
      const body = encodeURIComponent(`From: ${name} (${email})\n\n${message}`);
      window.location.href = `mailto:info@seankani.com?subject=${subject}&body=${body}`;
    });
  }

  // ═══════ CYCLING ROLES ═══════
  const re = document.querySelector('.role-text');
  if (re) {
    const darkRoles = [
      { t: 'Software Engineer', c: '#6EE7FF', g: '0 0 14px rgba(110,231,255,.5)' },
      { t: 'Product Builder', c: '#FFCF44', g: '0 0 14px rgba(255,207,68,.45)' },
      { t: 'Music Producer', c: '#FF6BDB', g: '0 0 14px rgba(255,107,219,.45)' },
    ];
    const lightRoles = [
      { t: 'Software Engineer', c: '#1A5F8A', g: 'none' },
      { t: 'Product Builder', c: '#B8540C', g: 'none' },
      { t: 'Music Producer', c: '#7B2D8E', g: 'none' },
    ];
    const getRoles = () => document.documentElement.classList.contains('light') ? lightRoles : darkRoles;
    let rs = getRoles();
    let ci = 0;
    re.textContent = rs[0].t; re.style.color = rs[0].c; re.style.textShadow = rs[0].g;
    setInterval(() => {
      rs = getRoles();
      re.style.opacity = '0'; re.style.transform = 'translateY(-10px)';
      setTimeout(() => {
        ci = (ci + 1) % rs.length;
        re.textContent = rs[ci].t; re.style.color = rs[ci].c; re.style.textShadow = rs[ci].g;
        re.style.transition = 'none'; re.style.transform = 'translateY(10px)';
        re.offsetHeight;
        re.style.transition = 'opacity .4s,transform .4s cubic-bezier(.16,1,.3,1),color .3s';
        re.style.opacity = '1'; re.style.transform = 'translateY(0)';
      }, 350);
    }, 3000);
  }
</script>
