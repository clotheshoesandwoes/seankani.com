      ctx.moveTo(bt.x,by-bt.sz*1.9);
      ctx.lineTo(bt.x-bt.sz*.6,by-bt.sz*.4);
      ctx.lineTo(bt.x,by-bt.sz*.6);
      ctx.closePath();ctx.fill();
    }

    // ── Ripples + dolphins ──
    for(let i=socalRipples.length-1;i>=0;i--){const rp=socalRipples[i],age=(now-rp.t)/1000;
      if(age>2){socalRipples.splice(i,1);continue;}ctx.beginPath();ctx.arc(rp.x,rp.y,age*30,0,6.28);
      ctx.strokeStyle=`rgba(255,255,255,${.12*(1-age/2)})`;ctx.lineWidth=1;ctx.stroke();}
    for(let i=socalDolphins.length-1;i>=0;i--){const dl=socalDolphins[i],age=(now-dl.t)/1000;
      if(age>1.2){socalDolphins.splice(i,1);continue;}const prog=age/1.2;
      const dx=dl.x+dl.vx*age*30,dy=dl.y-Math.sin(prog*3.14)*22;const angle=Math.atan2(-Math.cos(prog*3.14)*22,dl.vx*30);
      const fade=prog>.8?1-(prog-.8)/.2:Math.min(prog/.15,1);
      ctx.save();ctx.translate(dx,dy);ctx.rotate(angle);ctx.fillStyle=`rgba(55,75,95,${.32*fade})`;
      ctx.beginPath();ctx.ellipse(0,0,5.5,1.8,0,0,6.28);ctx.fill();
      ctx.beginPath();ctx.moveTo(-4.5,0);ctx.lineTo(-7,-2);ctx.lineTo(-7,2);ctx.fill();
      ctx.beginPath();ctx.moveTo(1,-1.2);ctx.lineTo(0,-3.5);ctx.lineTo(-1,-1.2);ctx.fill();ctx.restore();}

    // Sun shimmer on water
    const sr=ctx.createLinearGradient(0,waterStart,0,waterStart+25);
