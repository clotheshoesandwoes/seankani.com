      ctx.beginPath();ctx.moveTo(p.x,shoreY);ctx.quadraticCurveTo(p.x+p.lean*p.h*.5,shoreY-p.h*.5,topX,topY);ctx.stroke();
      for(let fi=0;fi<7;fi++){
