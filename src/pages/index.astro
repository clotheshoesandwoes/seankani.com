      ctx.strokeStyle='rgba(60,45,30,.85)';ctx.lineWidth=1.2;
      ctx.beginPath();ctx.moveTo(bt.x,by-2);ctx.lineTo(bt.x,by-bt.sz*1.9);ctx.stroke();
      // Main sail — solid white
      ctx.fillStyle='rgba(255,255,255,.95)';
      ctx.beginPath();
      ctx.moveTo(bt.x,by-bt.sz*1.9);
