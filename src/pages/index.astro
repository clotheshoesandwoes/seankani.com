---
import Layout from '../layouts/Base.astro';
---

<Layout title="Sean Kani">
  <main class="hero">
    <h1>Sean Kani</h1>
    <p class="tagline">Builder of things.</p>

    <section class="projects">
      <h2>Projects</h2>
      <div class="project-grid">
        <a class="project-card" href="https://gridon.life" target="_blank">
          <h3>The Grid</h3>
          <p>Personal productivity OS — life dashboard, journal, tasks, habits, finance, and more.</p>
        </a>
      </div>
    </section>
  </main>
</Layout>

<style>
  .hero {
    max-width: 720px;
    margin: 0 auto;
    padding: 4rem 1.5rem;
  }

  h1 {
    font-size: 3rem;
    font-weight: 700;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .tagline {
    font-size: 1.25rem;
    color: #888;
    margin: 0.5rem 0 3rem;
  }

  h2 {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #666;
    margin-bottom: 1.5rem;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .project-card {
    display: block;
    padding: 1.5rem;
    border: 1px solid #222;
    border-radius: 12px;
    background: #0a0a0a;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, transform 0.2s;
  }

  .project-card:hover {
    border-color: #555;
    transform: translateY(-2px);
  }

  .project-card h3 {
    font-size: 1.25rem;
    margin: 0 0 0.5rem;
  }

  .project-card p {
    font-size: 0.9rem;
    color: #999;
    margin: 0;
    line-height: 1.5;
  }

  @media (max-width: 600px) {
    .hero {
      padding: 2.5rem 1rem;
    }

    h1 {
      font-size: 2.25rem;
    }
  }
</style>
