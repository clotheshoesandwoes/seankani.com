    ctx.fillStyle=sand;ctx.fillRect(0,shoreY,W2,waterStart-shoreY);

    // ── Palm trees — spread across beachfront ──
    for(const p of socalPalms){
      if(p.x>W2*.92)continue;
      const sway=Math.sin(now*.001+p.phase)*3;
