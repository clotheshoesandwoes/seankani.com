      ctx.fillStyle='rgba(165,105,58,.18)';
      ctx.beginPath();ctx.moveTo(m.x-1,my);ctx.lineTo(m.x+m.w/2,my-m.h*.5);ctx.lineTo(m.x+m.w+1,my);ctx.fill();
      ctx.fillStyle='rgba(115,175,220,.22)';ctx.fillRect(m.x+2,my+2,2,2);ctx.fillRect(m.x+m.w-4,my+2,2,2);
    }

    // ── Hollywood-style sign — drawn at tagline position ──
    const tgEl=document.querySelector('.tagline');
    if(tgEl){
      const tgRect=tgEl.getBoundingClientRect();
      const signY=tgRect.top+tgRect.height/2;
      const signDisplay='BUILDER OF THINGS';
      const signFontSz=Math.max(14,Math.min(W2*.02,30));
      ctx.font=`900 ${signFontSz}px Inter,sans-serif`;
      const charW=signFontSz*.9;
      const totalW=signDisplay.length*charW;
      const startX=W2*.5-totalW/2;
      for(let li=0;li<signDisplay.length;li++){
