---
import Layout from '../layouts/Base.astro';
---

<Layout title="Sean Kani — Builder of things">
  <div class="bg-glow" aria-hidden="true">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
  </div>
  <div class="noise" aria-hidden="true"></div>
  <canvas class="city-canvas" aria-hidden="true"></canvas>
  <div class="spotlight" aria-hidden="true"></div>

  <!-- Theme toggle -->
  <button class="theme-toggle" aria-label="Switch theme" title="Toronto / SoCal">
    <svg class="toggle-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
    <svg class="toggle-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
  </button>

  <main>
    <section class="hero">
      <h1>
        <span class="line"><span class="word" style="--i:0">Sean</span></span>
        <span class="line"><span class="word" style="--i:1">Kani</span></span>
      </h1>
      <div class="color-line" aria-hidden="true"></div>
      <p class="tagline anim-fade" style="--d:0.65s">Builder of things.</p>
      <div class="roles anim-fade" style="--d:0.85s"><span class="role-text"></span></div>
      <a href="#work" class="cta anim-fade" style="--d:1.1s">
        View work
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
      </a>
    </section>

    <section id="work" class="work">
      <h2 class="label" data-reveal>Selected Work</h2>
      <div class="projects">
        <a href="https://gridon.life" target="_blank" rel="noopener" class="project" data-reveal style="--accent: 139, 92, 246">
          <span class="project-num">01</span>
          <div class="project-info">
            <h3>The Grid</h3>
            <p>An all-in-one life operating system. Journal, tasks, habits, finance, health — everything connected, nothing lost.</p>
            <span class="project-meta">Productivity · Full-Stack · SaaS</span>
          </div>
          <svg class="project-arrow" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
        </a>
        <a href="https://advertra.ca" target="_blank" rel="noopener" class="project" data-reveal style="--accent: 245, 158, 11">
          <span class="project-num">02</span>
          <div class="project-info">
            <h3>Advertra</h3>
            <p>Building the Client Storm Tracker for a home-service lead gen company. Real-time pipeline visibility for contractors.</p>
            <span class="project-meta">Dev Work · Lead Gen · Beta</span>
          </div>
          <svg class="project-arrow" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
        </a>
        <a href="https://cantmute.me" target="_blank" rel="noopener" class="project" data-reveal style="--accent: 244, 63, 94">
          <span class="project-num">03</span>
          <div class="project-info">
            <h3>Can't Mute Me</h3>
            <p>Music portfolio — beats, production, and everything sound. The creative side.</p>
            <span class="project-meta">Music · Portfolio · Creative</span>
          </div>
          <svg class="project-arrow" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
        </a>
        <a href="https://cantmute.me" target="_blank" rel="noopener" class="project" data-reveal style="--accent: 200, 80, 180">
          <span class="project-num">04</span>
          <div class="project-info">
            <h3>Drift</h3>
            <p>A vocal reverb plugin for producers. Lush, spatial, and made for voices. Coming soon under Can't Mute Me.</p>
            <span class="project-meta">Audio Plugin · DSP · Coming Soon</span>
          </div>
          <svg class="project-arrow" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
        </a>
      </div>
    </section>

    <!-- ═══════ CONTACT ═══════ -->
    <section id="contact" class="contact" data-reveal>
      <h2 class="contact-headline">Got an idea?</h2>
      <p class="contact-sub">Tell me about it. I turn half-baked ideas into living, breathing products.</p>

      <form class="contact-form">
        <div class="form-row">
          <input type="text" name="name" placeholder="Your name" required autocomplete="name" />
          <input type="email" name="email" placeholder="Your email" required autocomplete="email" />
        </div>
        <textarea name="message" placeholder="What's the idea?" rows="5" required></textarea>
        <button type="submit" class="form-btn">Send it</button>
      </form>
    </section>

    <footer class="footer">
      <nav class="footer-nav">
        <a href="https://www.instagram.com/seankani" target="_blank" rel="noopener">Instagram</a>
        <a href="mailto:info@seankani.com">Email</a>
      </nav>
      <small>&copy; 2026 Sean Kani</small>
    </footer>
  </main>
</Layout>

<style>
  .bg-glow { position:fixed; inset:0; z-index:0; overflow:hidden; pointer-events:none; }
  .orb { position:absolute; border-radius:50%; filter:blur(120px); will-change:transform; }
  .orb-1 { width:650px;height:650px;background:radial-gradient(circle,rgba(139,92,246,.18),transparent 70%);top:-15%;right:-10%;animation:d1 22s ease-in-out infinite; }
  .orb-2 { width:550px;height:550px;background:radial-gradient(circle,rgba(245,158,11,.12),transparent 70%);bottom:10%;left:-8%;animation:d2 28s ease-in-out infinite; }
  .orb-3 { width:500px;height:500px;background:radial-gradient(circle,rgba(244,63,94,.12),transparent 70%);top:50%;left:50%;animation:d3 25s ease-in-out infinite; }
  @keyframes d1{0%,100%{transform:translate(0,0) scale(1)}33%{transform:translate(-60px,40px) scale(1.05)}66%{transform:translate(40px,-30px) scale(.95)}}
  @keyframes d2{0%,100%{transform:translate(0,0) scale(1)}33%{transform:translate(50px,-40px) scale(1.05)}66%{transform:translate(-40px,50px) scale(.95)}}
  @keyframes d3{0%,100%{transform:translate(0,0) scale(1)}33%{transform:translate(-40px,-50px) scale(1.08)}66%{transform:translate(50px,30px) scale(.92)}}
  .noise { position:fixed;inset:0;z-index:1;pointer-events:none;opacity:.03;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.7' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");background-repeat:repeat;background-size:200px 200px; }
  .city-canvas { position:fixed;inset:0;z-index:2;pointer-events:none;opacity:0;animation:cin 2.5s ease-out .5s forwards; }
  @keyframes cin{to{opacity:1}}
  .spotlight { position:fixed;inset:0;z-index:3;pointer-events:none; }
  :root.light .bg-glow, :root.light .noise, :root.light .spotlight { opacity:0; }
  :root.light .color-line { visibility:hidden; }
  :root.light h1 { color:#fff;text-shadow:0 2px 12px rgba(0,0,0,.3),0 1px 3px rgba(0,0,0,.2); }
  :root.light .role-text { text-shadow:0 1px 6px rgba(0,0,0,.25); }
  :root.light .cta { border-color:rgba(255,255,255,.5);background:rgba(255,255,255,.15);box-shadow:0 0 12px rgba(255,255,255,.08); }
  :root.light .cta:hover { border-color:#fff;background:rgba(255,255,255,.25);box-shadow:0 0 20px rgba(255,255,255,.15); }
  main { position:relative; z-index:4; overflow-x:clip; max-width:100vw; }

  /* Theme toggle */
  .theme-toggle {
    position:fixed;top:1.25rem;right:1.25rem;z-index:50;
    width:40px;height:40px;border-radius:50%;border:1px solid var(--card-border);
    background:var(--card-bg);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);
    cursor:pointer;display:flex;align-items:center;justify-content:center;
    color:var(--text-muted);transition:all .3s;
  }
  .theme-toggle:hover { border-color:var(--text-dim);color:var(--text); transform:scale(1.1); }
  .toggle-sun { display:none; }
  :root.light .toggle-moon { display:none; }
  :root.light .toggle-sun { display:block; }

  .hero { display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;padding:2rem;text-align:center; }
  h1 { font-size:clamp(3.5rem,12vw,9rem);font-weight:800;line-height:.95;letter-spacing:-.04em;margin-bottom:1.5rem; }
  .line { display:block;overflow:hidden; }
  .word { display:inline-block;opacity:0;transform:translateY(105%);animation:wu .9s cubic-bezier(.16,1,.3,1) forwards;animation-delay:calc(var(--i)*.12s + .2s); }
  @keyframes wu{to{opacity:1;transform:translateY(0)}}
  .color-line { width:48px;height:2px;margin:0 auto 1.5rem;border-radius:2px;background:linear-gradient(90deg,rgb(139,92,246),rgb(245,158,11),rgb(244,63,94),rgb(139,92,246));background-size:300% 100%;opacity:0;transform:scaleX(0);animation:lr .8s cubic-bezier(.16,1,.3,1) .45s forwards,gs 4s ease-in-out 1.2s infinite; }
  @keyframes lr{to{opacity:1;transform:scaleX(1)}}
  @keyframes gs{0%,100%{background-position:0% 50%}50%{background-position:100% 50%}}
  .tagline { font-size:clamp(1rem,2.5vw,1.35rem);font-weight:600;color:rgba(255,255,255,.85);margin-bottom:.6rem;font-variant-ligatures:none; }
  :root.light .tagline { visibility:hidden; }
  .roles { height:1.8em;margin-bottom:2.25rem;overflow:hidden; }
  .role-text { display:inline-block;font-size:clamp(.85rem,2vw,1.05rem);font-weight:500;letter-spacing:.04em;transition:opacity .4s,transform .4s cubic-bezier(.16,1,.3,1),color .3s; }
  .anim-fade { opacity:0;transform:translateY(18px);animation:fu .8s cubic-bezier(.16,1,.3,1) forwards;animation-delay:var(--d); }
  @keyframes fu{to{opacity:1;transform:translateY(0)}}
  .cta { display:inline-flex;align-items:center;gap:.5rem;padding:.65rem 1.6rem;border:1px solid rgba(255,255,255,.25);border-radius:100px;font-size:.875rem;font-weight:500;color:rgba(255,255,255,.85);text-decoration:none;transition:border-color .3s,color .3s,transform .15s ease-out,box-shadow .3s;will-change:transform;backdrop-filter:blur(4px);background:rgba(255,255,255,.06);box-shadow:0 0 12px rgba(255,255,255,.06); }
  .cta:hover { border-color:rgba(255,255,255,.5);color:#fff;box-shadow:0 0 20px rgba(255,255,255,.12); }
  .cta svg { transition:transform .3s; }
  .cta:hover svg { transform:translateY(2px); }

  .work { max-width:1000px;margin:0 auto;padding:2rem 2rem 8rem;position:relative;z-index:2;overflow-x:clip; }
  .projects { overflow-x:clip; }
  .work::before { content:'';position:absolute;inset:-2rem 0;background:linear-gradient(180deg,transparent,rgba(0,0,0,.3) 8%,rgba(0,0,0,.4) 50%,rgba(0,0,0,.3) 92%,transparent);border-radius:24px;backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);z-index:-1;pointer-events:none; }
  :root.light .work::before { background:linear-gradient(180deg,transparent,rgba(248,246,242,.32) 8%,rgba(248,246,242,.45) 50%,rgba(248,246,242,.32) 92%,transparent); }
  .label { font-size:.8rem;font-weight:600;text-transform:uppercase;letter-spacing:.14em;color:#b0b0b6;margin-bottom:3rem;text-align:center; }
  :root.light .label { color:#444; }
  .projects { display:flex;flex-direction:column; }
  .project { display:grid;grid-template-columns:56px 1fr 40px;align-items:start;gap:2rem;padding:3rem 0;border-top:1px solid var(--card-border);text-decoration:none;color:inherit;position:relative;transition:all .5s cubic-bezier(.16,1,.3,1); }
  .project:last-child { border-bottom:1px solid var(--card-border); }
  .project::before { content:'';position:absolute;left:-2rem;top:0;bottom:0;width:2px;background:rgba(var(--accent),0);border-radius:2px;transition:background .5s cubic-bezier(.16,1,.3,1); }
  .project:hover::before { background:rgba(var(--accent),.6); }
  .project::after { content:'';position:absolute;inset:-1rem -2rem;border-radius:16px;background:radial-gradient(ellipse at left,rgba(var(--accent),.04),transparent 70%);opacity:0;transition:opacity .5s;pointer-events:none;z-index:-1; }
  .project:hover::after { opacity:1; }
  .project:hover { padding-left:1rem; }
  .project-num { font-size:.85rem;font-weight:600;color:rgba(var(--accent),.4);padding-top:.5rem;font-variant-numeric:tabular-nums;transition:color .4s; }
  .project:hover .project-num { color:rgba(var(--accent),.9); }
  .project-info h3 { font-size:clamp(1.75rem,4vw,2.75rem);font-weight:700;letter-spacing:-.03em;line-height:1.1;margin-bottom:.85rem;transition:color .4s; }
  .project:hover .project-info h3 { color:rgb(var(--accent)); }
  .project-info p { font-size:1rem;line-height:1.65;color:#cfcfd2;margin-bottom:1rem;max-width:520px; }
  .project-meta { font-size:.8rem;font-weight:500;color:#9a9aa0;letter-spacing:.04em;transition:color .3s; }
  :root.light .project-info p { color:#2a2a2a; }
  :root.light .project-meta { color:#555; }
  .project:hover .project-meta { color:#bbb; }
  :root.light .project:hover .project-meta { color:#222; }
  .project-arrow { color:#666;margin-top:.5rem;transition:transform .4s cubic-bezier(.16,1,.3,1),color .4s; }
  .project:hover .project-arrow { color:rgba(var(--accent),.7);transform:translate(5px,-5px); }

  /* ═══════ CONTACT ═══════ */
  .contact { max-width:640px;margin:0 auto;padding:4rem 2rem 6rem;text-align:center; }
  .contact-headline { font-size:clamp(1.75rem,5vw,2.75rem);font-weight:700;letter-spacing:-.03em;margin-bottom:1rem; }
  .contact-sub { font-size:1rem;color:var(--text-muted);line-height:1.6;margin-bottom:2.5rem;max-width:440px;margin-left:auto;margin-right:auto; }
  .contact-form { display:flex;flex-direction:column;gap:1rem; }
  .form-row { display:grid;grid-template-columns:1fr 1fr;gap:1rem; }
  .contact-form input, .contact-form textarea {
    width:100%;padding:1rem 1.15rem;background:var(--input-bg);
    border:1px solid var(--input-border);border-radius:10px;
    color:var(--text);font-family:inherit;font-size:.95rem;resize:vertical;
    transition:border-color .3s,box-shadow .3s;
  }
  .contact-form input::placeholder, .contact-form textarea::placeholder { color:var(--text-dim); }
  .contact-form input:focus, .contact-form textarea:focus {
    outline:none;border-color:rgba(139,92,246,.4);
    box-shadow:0 0 24px rgba(139,92,246,.08);
  }
  .form-btn {
    align-self:center;padding:.85rem 2.5rem;margin-top:.5rem;
    background:var(--btn-bg);border:1px solid var(--btn-border);
    border-radius:100px;color:var(--btn-text);font-family:inherit;font-weight:600;
    font-size:.9rem;cursor:pointer;letter-spacing:.02em;
    transition:all .3s cubic-bezier(.16,1,.3,1);
  }
  .form-btn:hover { background:var(--glow);color:var(--text);border-color:var(--text-dim);transform:translateY(-2px); }
  .form-btn:disabled { opacity:.6;cursor:not-allowed;transform:none; }

  .footer { text-align:center;padding:2.5rem 1.5rem 3rem;border-top:1px solid var(--footer-line); }
  .footer-nav { display:flex;justify-content:center;gap:1.5rem;margin-bottom:2.5rem; }
  .footer-nav a { font-size:.9rem;color:var(--text-muted);text-decoration:none;position:relative;transition:color .3s; }
  .footer-nav a::after { content:'';position:absolute;bottom:-2px;left:0;width:0;height:1px;background:var(--text);transition:width .3s cubic-bezier(.16,1,.3,1); }
  .footer-nav a:hover { color:var(--text); }
  .footer-nav a:hover::after { width:100%; }
  .footer small { font-size:.75rem;color:var(--text-faint); }

  [data-reveal] { opacity:0;transform:translateY(32px);transition:opacity .7s cubic-bezier(.16,1,.3,1),transform .7s cubic-bezier(.16,1,.3,1); }
  [data-reveal].is-visible { opacity:1;transform:none; }
  .project[data-reveal]:nth-child(2) { transition-delay:.1s; }
  .project[data-reveal]:nth-child(3) { transition-delay:.2s; }
  .project[data-reveal]:nth-child(4) { transition-delay:.3s; }

  @media(max-width:680px) {
    .form-row { grid-template-columns:1fr; }
    .contact { padding:3rem 1.25rem 5rem; max-width:100%; }
    .work { padding:2rem 1.25rem 5rem; }
    .project { display:flex;flex-direction:column;gap:0;padding:2.25rem 0;position:relative; }
    .project:hover { padding-left:0; }
    .project::before { left:0; }
    .project::after { inset:-1rem 0; }
    .project-num { margin-bottom:.75rem; }
    .project-arrow { position:absolute;top:2.25rem;right:0; }
    .project-info p { max-width:100%; }
    .hero { padding:1.5rem; }
    h1 { word-break:break-word; }
  }
</style>

<script>
  // ═══════ SCROLL REVEAL ═══════
  const ro = new IntersectionObserver(
    (es) => es.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('is-visible'); ro.unobserve(e.target); } }),
    { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('[data-reveal]').forEach((el) => ro.observe(el));

  // ═══════ TORONTO SKYLINE v2 ═══════
  const cv = document.querySelector('.city-canvas');
  const noMo = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (cv && !noMo) {
    const cx = cv.getContext('2d');
    const dpr = window.devicePixelRatio || 1;
    let W = 0, H = 0, sOp = 1, waterY = 0, landY = 0, mob = false;
    const ms = { x: -9e3, y: -9e3 };
    const C = [[139,92,246],[245,158,11],[244,63,94]];
    const isMob = 'ontouchstart' in window || window.innerWidth < 768;
    const DR = isMob ? 40 : 90; // smaller blast radius on mobile
    const CH = 6, GR = 0.12, RS = 0.006;
    let blds = [], splashes = [];
    let boats = [], cars = [], fireworks = [], parkItems = [];
    let cranes = [], helis = [], planes = [];
    // Time-of-day: 0=midnight, .5=noon, sync to local hour, advance ~1 cycle/4min
    const startHour = new Date().getHours() + new Date().getMinutes()/60;
    let tod = startHour / 24;
    let touchActive = false;

    function rsz() {
      W = window.innerWidth; H = window.innerHeight;
      mob = W < 768;
      landY = mob ? H * 0.83 : H * 0.84;
      waterY = mob ? H * 0.87 : H * 0.88;
      cv.width = W * dpr; cv.height = H * dpr;
      cv.style.width = W + 'px'; cv.style.height = H + 'px';
      cx.setTransform(dpr, 0, 0, dpr, 0, 0);
      splashes = []; genTO(); genStars();
    }

    // Warm white, cool white, amber, blue tints for window variety
    const WC = [[255,240,200],[200,220,255],[255,200,130],[180,255,220],[255,180,180],[255,255,255]];

    function mkB(x, y, w, h, sp) {
      const wins = [];
      // Each building gets a dominant tint
      const tint = C[~~(Math.random() * 3)];
      const bodyAlpha = .04 + Math.random() * .04; // vary building brightness
      if (!sp || sp === 'cn-shaft') {
        for (let wy = y + 4; wy < y + h - 3; wy += 6) {
          for (let wx = x + 2; wx < x + w - 2; wx += 5) {
            if (Math.random() > 0.15) {
              // Mix of warm whites, accent colors, and project colors
              const wc = Math.random() > .4 ? WC[~~(Math.random() * WC.length)] : C[~~(Math.random() * 3)];
              wins.push({ rx: wx - x, ry: wy - y, w: 2, h: 2.5, r: wc[0], g: wc[1], b: wc[2], a: 0.15 + Math.random() * 0.6, f: Math.random() * 6.28 });
            }
          }
        }
      }
      return { x, y, w, h, wins, sp: sp || null, ok: true, db: [], dt: 0, rp: 0, rb: false, tint, bodyAlpha };
    }

    function genTO() {
      blds = [];
      const s = Math.max(W / 1400, 0.45);
      const g = landY;
      const mH = mob ? Math.min(H * 0.52, 420) : Math.min(H * 0.62, 520);
      const zones = [
        [0, .10, .10, .22, .7],
        [.10, .22, .18, .40, .85],
        [.22, .26, .15, .30, .5],  // stop before dome at .27
        [.44, .48, .12, .25, .55],
        [.48, .72, .45, .85, .95],  // financial district — taller, denser
        [.72, .88, .30, .60, .88],  // right side — taller, more filled
        [.88, 1.02, .12, .30, .75],
      ];
      for (const z of zones) {
        let x = z[0] * W;
        while (x < z[1] * W) {
          const w = (10 + Math.random() * 30) * s;
          const h = (z[2] + Math.random() * (z[3] - z[2])) * mH;
          if (Math.random() < z[4]) blds.push(mkB(x, g - h, w, h));
          x += w + Math.random() * 3 * s;
        }
      }
      // Dome
      const dX = mob ? W * 0.02 : W * 0.27;
      const dW = mob ? Math.max(40, 50 * s) : Math.max(65, 85 * s);
      const dH = mob ? Math.max(18, 25 * s) : Math.max(28, 40 * s);
      blds.push({ x: dX, y: g - dH, w: dW, h: dH, wins: [], sp: 'dome', ok: true, db: [], dt: 0, rp: 0, rb: false });
      // CN Tower
      const cnX = mob ? W * 0.18 : W * 0.38; // push CN Tower to the left on mobile
      const tCN = mob ? mH * 1.5 : mH * 1.6;
      const shH = tCN * .5, supH = tCN * .07, podH = tCN * .1, upH = tCN * .33;
      const shW = Math.max(20, 26 * s), supW = Math.max(26, 34 * s);
      const podW = Math.max(44, 56 * s), upW = Math.max(3, 4 * s);
      blds.push(mkB(cnX - shW / 2, g - shH, shW, shH, 'cn-shaft'));
      blds.push(mkB(cnX - supW / 2, g - shH - supH, supW, supH, 'cn-sup'));
      blds.push(mkB(cnX - podW / 2, g - shH - supH - podH, podW, podH, 'cn-pod'));
      blds.push(mkB(cnX - upW / 2, g - shH - supH - podH - upH, upW, upH, 'cn-upper'));

      // Harbor boats — more, including a bigger cruise/ferry
      boats=[];
      for(let i=0;i<8;i++) boats.push({x:W*.05+Math.random()*W*.9,y:waterY+6+Math.random()*(H-waterY-20),sz:i===0?22:10+Math.random()*12,sp:.06+Math.random()*.12*(Math.random()>.5?1:-1),bob:Math.random()*6.28,c:C[~~(Math.random()*3)],big:i===0});

      // Pre-generate park items (trees + streetlights + benches) — STATIC positions
      // Denser greenery — Toronto Music Garden / HTO Park / Trillium feel
      parkItems=[];
      const pkSpacing=Math.max(12,18*(W/1400));
      let pkCount=0;
      for(let tx=10;tx<W;tx+=pkSpacing+Math.sin(tx*.3)*4){
        let blocked=false;
        for(const b of blds){if(tx>b.x-2&&tx<b.x+b.w+2&&b.sp!=='dome'){blocked=true;break;}}
        if(blocked) continue;
        pkCount++;
        const r=pkCount%7;
        let type='tree';
        if(r===0) type='light';
        else if(r===3) type='bench';
        else if(r===5) type='bush';
        const nearLight=r===1||r===6;
        parkItems.push({x:tx,type,nearLight,size:7+Math.sin(tx*.7)*3+3});
      }

      // Animated construction cranes — boom rotates, hook lifts cargo
      cranes=[];
      const craneSpots=[W*.5,W*.64,W*.8];
      for(let i=0;i<craneSpots.length;i++){
        const cBase=craneSpots[i];
        cranes.push({x:cBase,h:80+Math.sin(cBase)*30,boomLen:45,
          armPhase:Math.random()*6.28, armSpeed:.0018+Math.random()*.0025,
          hookPhase:Math.random()*6.28, hookSpeed:.008+Math.random()*.014,
          cargoOn:Math.random()>.5, blinkOff:Math.random()*6.28});
      }

      // One helicopter — lower, near the skyline
      helis=[{x:Math.random()*W,y:H*.36,
        vx:.5,
        rotor:0, searchPhase:Math.random()*6.28}];

      // High-altitude plane — below the moon (moon is at H*.12), opposite direction, staggered start
      planes=[{x:W+300,y:H*.20,vx:-.55, navBlink:0}];

      // Cars on Gardiner (moving lights along the waterfront)
      cars=[];
      const types=['sedan','sedan','sedan','suv','suv','semi','semi','cop'];
      for(let i=0;i<12;i++){
        const t=types[~~(Math.random()*types.length)];
        const dir=Math.random()>.5?1:-1;
        cars.push({x:Math.random()*W,sp:(t==='semi'?.5:.8)+Math.random()*(t==='semi'?.5:1.5),dir,type:t,
          c:t==='cop'?[60,120,255]:dir>0?[255,220,150]:[255,60,60],siren:0});
      }

    }

    function smash(b) {
      b.ok = false; b.dt = performance.now(); b.db = [];
      const bcx = b.x + b.w / 2, bcy = b.y + b.h / 2;
      const ang = Math.atan2(bcy - ms.y, bcx - ms.x);
      for (let px = 0; px < b.w; px += CH) {
        for (let py = 0; py < b.h; py += CH) {
          const cw = Math.min(CH, b.w - px), ch = Math.min(CH, b.h - py);
          const spr = (Math.random() - .5) * 2.2, pow = 1.5 + Math.random() * 3.5;
          const lit = Math.random() > .6; const c = C[~~(Math.random() * 3)];
          b.db.push({ x: b.x + px, y: b.y + py, vx: Math.cos(ang + spr) * pow + (Math.random() - .5),
            vy: Math.sin(ang + spr) * pow - Math.random() * 4,
            w: cw, h: ch, rot: 0, rv: (Math.random() - .5) * .15,
            r: lit ? c[0] : 140, g: lit ? c[1] : 140, b: lit ? c[2] : 155,
            ba: lit ? .55 : .25, a: 1, gn: false, sunk: false });
        }
      }
      if (b.sp === 'cn-shaft') for (const o of blds) { if ((o.sp==='cn-sup'||o.sp==='cn-pod'||o.sp==='cn-upper')&&o.ok) smash(o); }
      if (b.sp === 'cn-sup') for (const o of blds) { if ((o.sp==='cn-pod'||o.sp==='cn-upper')&&o.ok) smash(o); }
      if (b.sp === 'cn-pod') for (const o of blds) { if (o.sp==='cn-upper'&&o.ok) smash(o); }
    }

    function drawPerson(x, y, now) {
      const t = now * .004;
      const bob = Math.sin(t) * 2;
      const px = x, py = y + bob;
      // Dance phases — arms and legs move rhythmically
      const armL = Math.sin(t * 1.5) * 0.8; // left arm wave
      const armR = Math.sin(t * 1.5 + 1.5) * 0.6;
      const legL = Math.sin(t * 1.5) * 2;
      const legR = Math.sin(t * 1.5 + 3.14) * 2;
      const lean = Math.sin(t * .75) * 1.5; // body sway

      cx.save();
      cx.translate(px + lean, py);
      cx.strokeStyle = 'rgba(255,255,255,.6)'; cx.lineWidth = 1.3;
      cx.fillStyle = 'rgba(255,255,255,.7)';
      // Head
      cx.beginPath(); cx.arc(0, -10, 2.5, 0, 6.28); cx.fill();
      // Body
      cx.beginPath(); cx.moveTo(0, -7.5); cx.lineTo(0, 0); cx.stroke();
      // Left arm — reaching up and waving (Drake Hotline Bling)
      cx.beginPath(); cx.moveTo(0, -5); cx.lineTo(-4, -9 + armL * 2); cx.stroke();
      // Right arm — out to the side, swaying
      cx.beginPath(); cx.moveTo(0, -5); cx.lineTo(4, -3 + armR * 2); cx.stroke();
      // Left leg
      cx.beginPath(); cx.moveTo(0, 0); cx.lineTo(-2 + legL * .3, 5); cx.stroke();
      // Right leg
      cx.beginPath(); cx.moveTo(0, 0); cx.lineTo(2 + legR * .3, 5); cx.stroke();
      cx.restore();
    }

    function drawTree(x, y, size, now, lit) {
      const sway = Math.sin(now * .001 + x * .1) * 1.2;
      const sx = x + sway;
      // Shadow on ground
      cx.beginPath(); cx.ellipse(x, y + size * .5, size * .4, 2, 0, 0, 6.28);
      cx.fillStyle = 'rgba(0,0,0,.06)'; cx.fill();
      // Trunk with taper
      cx.beginPath();
      cx.moveTo(x - 1.5, y + size * .5);
      cx.lineTo(x + 1.5, y + size * .5);
      cx.lineTo(sx + .8, y - size * .1);
      cx.lineTo(sx - .8, y - size * .1);
      cx.fillStyle = 'rgba(55,40,25,.3)'; cx.fill();
      // Dark canopy layer (back)
      cx.beginPath(); cx.arc(sx - size * .12, y - size * .05, size * .38, 0, 6.28);
      cx.fillStyle = 'rgba(18,45,18,.18)'; cx.fill();
      cx.beginPath(); cx.arc(sx + size * .12, y - size * .1, size * .35, 0, 6.28);
      cx.fillStyle = 'rgba(20,50,20,.16)'; cx.fill();
      // Mid canopy
      cx.beginPath(); cx.arc(sx, y - size * .2, size * .42, 0, 6.28);
      cx.fillStyle = 'rgba(28,65,28,.18)'; cx.fill();
      // Highlight canopy (top — lit by moonlight)
      cx.beginPath(); cx.arc(sx + 1, y - size * .3, size * .28, 0, 6.28);
      cx.fillStyle = 'rgba(50,90,45,.12)'; cx.fill();
      // If near a streetlight, add warm glow on canopy
      if (lit) {
        cx.beginPath(); cx.arc(sx, y - size * .15, size * .5, 0, 6.28);
        cx.fillStyle = 'rgba(255,220,150,.04)'; cx.fill();
      }
    }

    function drawBench(x, baseY) {
      // Park bench silhouette
      cx.strokeStyle='rgba(160,140,110,.28)'; cx.lineWidth=1;
      cx.beginPath(); cx.moveTo(x-4,baseY); cx.lineTo(x-4,baseY-2); cx.stroke();
      cx.beginPath(); cx.moveTo(x+4,baseY); cx.lineTo(x+4,baseY-2); cx.stroke();
      cx.fillStyle='rgba(140,120,90,.32)';
      cx.fillRect(x-5,baseY-3,10,1.2);
      cx.strokeStyle='rgba(140,120,90,.22)';
      cx.beginPath(); cx.moveTo(x-4,baseY-3); cx.lineTo(x-3,baseY-6); cx.stroke();
      cx.beginPath(); cx.moveTo(x+4,baseY-3); cx.lineTo(x+3,baseY-6); cx.stroke();
      cx.fillStyle='rgba(140,120,90,.22)';
      cx.fillRect(x-3.5,baseY-6.5,7,.8);
    }

    function drawBush(x, baseY, size) {
      // Low decorative shrub — multiple small canopy circles
      cx.fillStyle='rgba(35,75,32,.28)';
      cx.beginPath(); cx.arc(x-size*.3,baseY-size*.25,size*.45,0,6.28); cx.fill();
      cx.beginPath(); cx.arc(x+size*.3,baseY-size*.25,size*.45,0,6.28); cx.fill();
      cx.fillStyle='rgba(50,95,40,.22)';
      cx.beginPath(); cx.arc(x,baseY-size*.4,size*.5,0,6.28); cx.fill();
      cx.fillStyle='rgba(70,120,55,.18)';
      cx.beginPath(); cx.arc(x-size*.05,baseY-size*.55,size*.25,0,6.28); cx.fill();
    }

    function drawStreetlight(x, baseY, now) {
      const h = 18;
      // Pole
      cx.strokeStyle = 'rgba(180,180,170,.15)'; cx.lineWidth = 1.2;
      cx.beginPath(); cx.moveTo(x, baseY); cx.lineTo(x, baseY - h); cx.stroke();
      // Arm curving out
      cx.beginPath(); cx.moveTo(x, baseY - h);
      cx.quadraticCurveTo(x + 3, baseY - h - 2, x + 6, baseY - h + 1);
      cx.strokeStyle = 'rgba(180,180,170,.12)'; cx.lineWidth = 1; cx.stroke();
      // Lamp head
      cx.fillStyle = 'rgba(255,230,170,.2)';
      cx.fillRect(x + 4, baseY - h, 4, 2);
      // Lamp glow — warm cone of light
      const lg = cx.createRadialGradient(x + 6, baseY - h + 1, 0, x + 6, baseY - h + 1, 30);
      lg.addColorStop(0, 'rgba(255,220,150,.07)');
      lg.addColorStop(.4, 'rgba(255,200,120,.03)');
      lg.addColorStop(1, 'transparent');
      cx.fillStyle = lg;
      cx.fillRect(x - 24, baseY - h - 20, 60, 50);
      // Light cone on ground
      const gg = cx.createRadialGradient(x + 6, baseY + 2, 0, x + 6, baseY + 2, 20);
      gg.addColorStop(0, 'rgba(255,220,150,.05)');
      gg.addColorStop(1, 'transparent');
      cx.fillStyle = gg;
      cx.fillRect(x - 14, baseY - 8, 40, 20);
    }

    // ── Star field — generated once per resize ──
    let stars = [], shootStars = [];
    function genStars() {
      stars = [];
      const count = mob ? 80 : 220;
      for (let i = 0; i < count; i++) {
        stars.push({
          x: Math.random() * W,
          y: Math.random() * landY * .75, // only in upper sky
          r: Math.random() * 1.3 + .3,
          a: Math.random() * .6 + .15,
          tw: Math.random() * 6.28, // twinkle phase
          sp: .5 + Math.random() * 2, // twinkle speed
          hue: Math.random() > .85 ? (Math.random() > .5 ? '180,200,255' : '255,200,150') : '255,255,255',
        });
      }
    }

    function frame(now) {
      requestAnimationFrame(frame);
      if (sOp <= .001) return;
      if (typeof isDark !== 'undefined' && !isDark) { cx.clearRect(0, 0, W, H); return; }
      cx.clearRect(0, 0, W, H);

      // ── Night sky gradient ──
      const sg = cx.createLinearGradient(0, 0, 0, waterY);
      sg.addColorStop(0, 'rgba(3,5,15,.06)');
      sg.addColorStop(.3, 'rgba(5,8,20,.04)');
      sg.addColorStop(.6, 'rgba(10,15,35,.06)');
      sg.addColorStop(.85, 'rgba(25,18,30,.1)');
      sg.addColorStop(1, 'rgba(40,25,20,.12)');
      cx.fillStyle = sg; cx.fillRect(0, 0, W, waterY);

      // ── Light pollution glow behind skyline ──
      const lpg = cx.createLinearGradient(0, landY - 80, 0, landY);
      lpg.addColorStop(0, 'transparent');
      lpg.addColorStop(.4, 'rgba(255,180,100,.02)');
      lpg.addColorStop(.7, 'rgba(255,160,80,.04)');
      lpg.addColorStop(1, 'rgba(255,140,60,.06)');
      cx.fillStyle = lpg; cx.fillRect(W * .15, landY - 80, W * .75, 80);
      // Concentrated glow over financial district
      const fpg = cx.createRadialGradient(W * .6, landY, 0, W * .6, landY, W * .25);
      fpg.addColorStop(0, 'rgba(255,200,120,.05)');
      fpg.addColorStop(.5, 'rgba(255,160,80,.02)');
      fpg.addColorStop(1, 'transparent');
      cx.fillStyle = fpg; cx.fillRect(W * .35, landY - 120, W * .5, 120);

      // ── Stars ──
      for (const s of stars) {
        const twinkle = .5 + Math.sin(now * .001 * s.sp + s.tw) * .5;
        const a = s.a * twinkle;
        if (a < .02) continue;
        cx.beginPath(); cx.arc(s.x, s.y, s.r * (.7 + twinkle * .3), 0, 6.28);
        cx.fillStyle = `rgba(${s.hue},${a})`;
        cx.fill();
        // Subtle cross sparkle on brighter stars
        if (s.r > 1 && twinkle > .7) {
          const len = s.r * 3 * twinkle;
          cx.strokeStyle = `rgba(${s.hue},${a * .3})`;
          cx.lineWidth = .5;
          cx.beginPath(); cx.moveTo(s.x - len, s.y); cx.lineTo(s.x + len, s.y); cx.stroke();
          cx.beginPath(); cx.moveTo(s.x, s.y - len); cx.lineTo(s.x, s.y + len); cx.stroke();
        }
      }

      // ── Shooting stars ──
      if (Math.random() < .003) { // occasional
        shootStars.push({
          x: Math.random() * W * .8,
          y: Math.random() * landY * .3,
          vx: 3 + Math.random() * 4,
          vy: 1.5 + Math.random() * 2,
          life: 1,
          len: 20 + Math.random() * 30,
        });
      }
      for (let i = shootStars.length - 1; i >= 0; i--) {
        const ss = shootStars[i];
        ss.x += ss.vx; ss.y += ss.vy; ss.life -= .02;
        if (ss.life <= 0) { shootStars.splice(i, 1); continue; }
        const tailX = ss.x - ss.vx * ss.len / 5;
        const tailY = ss.y - ss.vy * ss.len / 5;
        const grad = cx.createLinearGradient(tailX, tailY, ss.x, ss.y);
        grad.addColorStop(0, 'transparent');
        grad.addColorStop(1, `rgba(255,255,255,${ss.life * .4})`);
        cx.strokeStyle = grad; cx.lineWidth = 1;
        cx.beginPath(); cx.moveTo(tailX, tailY); cx.lineTo(ss.x, ss.y); cx.stroke();
        // Bright head
        cx.beginPath(); cx.arc(ss.x, ss.y, 1, 0, 6.28);
        cx.fillStyle = `rgba(255,255,255,${ss.life * .6})`; cx.fill();
      }

      // ── Moon with bloom — lights up the city ──
      const moonX = W * 0.78, moonY = H * 0.12, moonR = 22;
      // Large ambient glow — illuminates the scene
      const mg2 = cx.createRadialGradient(moonX, moonY, 0, moonX, moonY, moonR * 18);
      mg2.addColorStop(0, 'rgba(200,215,255,.05)');
      mg2.addColorStop(.15, 'rgba(180,200,240,.03)');
      mg2.addColorStop(.5, 'rgba(150,170,220,.012)');
      mg2.addColorStop(1, 'transparent');
      cx.fillStyle = mg2; cx.fillRect(0, 0, W, H);
      // Tight bloom around moon
      const mg = cx.createRadialGradient(moonX, moonY, moonR, moonX, moonY, moonR * 6);
      mg.addColorStop(0, 'rgba(220,230,255,.1)');
      mg.addColorStop(.3, 'rgba(180,200,240,.04)');
      mg.addColorStop(1, 'transparent');
      cx.fillStyle = mg; cx.fillRect(moonX - moonR * 6, moonY - moonR * 6, moonR * 12, moonR * 12);
      // Moon body
      cx.beginPath(); cx.arc(moonX, moonY, moonR, 0, 6.28);
      cx.fillStyle = 'rgba(220,230,255,.18)'; cx.fill();
      cx.shadowColor = 'rgba(200,215,255,.6)'; cx.shadowBlur = 60;
      cx.beginPath(); cx.arc(moonX, moonY, moonR * .75, 0, 6.28);
      cx.fillStyle = 'rgba(235,240,255,.25)'; cx.fill();
      cx.shadowBlur = 0;
      // Moon surface detail
      cx.beginPath(); cx.arc(moonX - 5, moonY - 3, 3, 0, 6.28);
      cx.fillStyle = 'rgba(200,210,230,.06)'; cx.fill();
      cx.beginPath(); cx.arc(moonX + 6, moonY + 4, 2, 0, 6.28);
      cx.fillStyle = 'rgba(200,210,230,.05)'; cx.fill();

      // ── Toronto Islands silhouette across the harbor ──
      // Distant strip of land with trees + the iconic Centre Island gazebo / Hanlan's Point lighthouse
      const islY = waterY + (H - waterY) * .25;
      const islGrad = cx.createLinearGradient(0, islY - 8, 0, islY + 4);
      islGrad.addColorStop(0, 'rgba(15,20,35,.35)');
      islGrad.addColorStop(1, 'rgba(20,25,40,.45)');
      cx.fillStyle = islGrad;
      cx.beginPath();
      cx.moveTo(0, islY);
      // Wavy island top with two distinct islands
      for(let ix = 0; ix <= W; ix += 8){
        let iy = islY;
        // Centre Island bump
        if(ix > W*.15 && ix < W*.55){
          iy -= 6 + Math.sin((ix - W*.15) / (W*.4) * Math.PI) * 5;
        }
        // Ward's Island bump
        if(ix > W*.6 && ix < W*.85){
          iy -= 4 + Math.sin((ix - W*.6) / (W*.25) * Math.PI) * 3;
        }
        cx.lineTo(ix, iy);
      }
      cx.lineTo(W, islY + 4);
      cx.lineTo(0, islY + 4);
      cx.closePath();
      cx.fill();
      // Tree silhouettes on the islands
      for(let ix = W*.16; ix < W*.84; ix += W*.022){
        if(ix > W*.55 && ix < W*.6) continue; // gap between islands
        const treeBaseY = islY - (ix > W*.6 ? 4 : 6) - Math.sin((ix - W*.15) / (W*.4) * Math.PI) * (ix > W*.6 ? 3 : 5);
        cx.fillStyle = 'rgba(10,15,25,.5)';
        cx.beginPath();
        cx.arc(ix, treeBaseY - 2, 2.5 + Math.sin(ix*.3), 0, 6.28);
        cx.fill();
      }
      // Tiny Hanlan's Point lighthouse — blinking
      const lhX = W*.72, lhY = islY - 8;
      cx.fillStyle = 'rgba(220,210,200,.4)';
      cx.fillRect(lhX-1.5, lhY, 3, 8);
      cx.fillStyle = 'rgba(180,170,160,.4)';
      cx.fillRect(lhX-2, lhY-2, 4, 2);
      if(Math.sin(now*.003) > .3){
        cx.beginPath(); cx.arc(lhX, lhY-1, 1.5, 0, 6.28);
        cx.fillStyle = 'rgba(255,230,150,.9)'; cx.fill();
        cx.shadowColor = 'rgba(255,220,140,.6)'; cx.shadowBlur = 8; cx.fill(); cx.shadowBlur = 0;
      }

      let cnPodOk = false, cnPodX = 0, cnPodY = 0;

      for (const b of blds) {
        if (b.ok) {
          const dx = Math.max(b.x - ms.x, 0, ms.x - (b.x + b.w));
          const dy = Math.max(b.y - ms.y, 0, ms.y - landY);
          const d = Math.sqrt(dx * dx + dy * dy);
          if (d < DR) { smash(b); continue; }
          let sx = 0;
          const shakeR = isMob ? DR * 1.3 : DR * 2;
          if (d < shakeR) sx = (Math.random() - .5) * (1 - d / shakeR) * (isMob ? 2 : 3);

          if (b.sp === 'dome') {
            const t = now * .0003, i0 = ~~t % 3, i1 = (i0 + 1) % 3, bl = t % 1;
            const pr = C[i0][0]+(C[i1][0]-C[i0][0])*bl, pg = C[i0][1]+(C[i1][1]-C[i0][1])*bl, pb = C[i0][2]+(C[i1][2]-C[i0][2])*bl;
            cx.beginPath(); cx.moveTo(b.x + sx, landY);
            cx.quadraticCurveTo(b.x + b.w * .5 + sx, b.y - b.h * .6, b.x + b.w + sx, landY);
            cx.fillStyle = `rgba(${pr},${pg},${pb},.08)`; cx.fill();
            cx.strokeStyle = `rgba(${pr},${pg},${pb},.25)`; cx.lineWidth = 1.5;
            cx.beginPath(); cx.moveTo(b.x + sx, landY);
            cx.quadraticCurveTo(b.x + b.w * .5 + sx, b.y - b.h * .6, b.x + b.w + sx, landY); cx.stroke();
            cx.fillStyle = 'rgba(255,255,255,.03)'; cx.fillRect(b.x + sx, landY - b.h * .3, b.w, b.h * .3);
            continue;
          }
          if (b.sp === 'cn-pod') {
            cnPodOk = true; cnPodX = b.x + b.w / 2 + sx; cnPodY = b.y;
            const t = now * .0003, i0 = ~~t % 3, i1 = (i0 + 1) % 3, bl = t % 1;
            const pr = C[i0][0]+(C[i1][0]-C[i0][0])*bl, pg = C[i0][1]+(C[i1][1]-C[i0][1])*bl, pb = C[i0][2]+(C[i1][2]-C[i0][2])*bl;
            const px = b.x + sx, py = b.y, pw = b.w, ph = b.h, cxM = px + pw/2;
            // Lower flared cone (SkyPod underside — widest at top, narrows into support)
            cx.fillStyle = `rgba(${pr},${pg},${pb},.1)`;
            cx.beginPath();
            cx.moveTo(cxM - pw*.18, py + ph);
            cx.lineTo(cxM + pw*.18, py + ph);
            cx.lineTo(px + pw, py + ph*.62);
            cx.lineTo(px + pw, py + ph*.48);
            cx.lineTo(px, py + ph*.48);
            cx.lineTo(px, py + ph*.62);
            cx.closePath();
            cx.fill();
            // Main observation deck — widest, brightest band (Glass Floor / LookOut level)
            cx.shadowColor = `rgba(${pr},${pg},${pb},.7)`; cx.shadowBlur = 22;
            cx.fillStyle = `rgba(${pr},${pg},${pb},.32)`;
            cx.fillRect(px, py + ph*.3, pw, ph*.2);
            cx.shadowBlur = 0;
            // Deck window band — bright horizontal dashes
            cx.fillStyle = 'rgba(255,255,255,.55)';
            const winCount = Math.max(6, ~~(pw/4));
            for (let i = 0; i < winCount; i++) {
              cx.fillRect(px + 1 + i * (pw-2)/winCount, py + ph*.36, (pw-2)/winCount*.6, 1.5);
            }
            // Upper 360 Restaurant tier — narrower disc
            cx.fillStyle = `rgba(${pr},${pg},${pb},.22)`;
            cx.fillRect(px + pw*.18, py + ph*.08, pw*.64, ph*.22);
            cx.fillStyle = 'rgba(255,255,255,.35)';
            cx.fillRect(px + pw*.22, py + ph*.15, pw*.56, 1);
            // Top dome/cap
            cx.fillStyle = `rgba(${pr},${pg},${pb},.18)`;
            cx.beginPath();
            cx.moveTo(px + pw*.18, py + ph*.08);
            cx.quadraticCurveTo(cxM, py - ph*.04, px + pw*.82, py + ph*.08);
            cx.fill();
            continue;
          }
          if (b.sp === 'cn-upper') {
            // Antenna/mast — thin tapered needle
            cx.fillStyle = 'rgba(180,200,255,.07)'; cx.beginPath();
            cx.moveTo(b.x + sx, b.y + b.h); cx.lineTo(b.x + b.w + sx, b.y + b.h);
            cx.lineTo(b.x + b.w * .5 + sx + .3, b.y); cx.lineTo(b.x + b.w * .5 + sx - .3, b.y); cx.fill();
            // Space Deck — small bump ~35% down the antenna
            const sdY = b.y + b.h * .35, sdW = b.w * 2.2;
            const sdCX = b.x + b.w / 2 + sx;
            cx.fillStyle = 'rgba(200,220,255,.15)';
            cx.fillRect(sdCX - sdW/2, sdY, sdW, 3);
            cx.fillStyle = 'rgba(255,255,255,.3)';
            cx.fillRect(sdCX - sdW/2 + 1, sdY + 1, sdW - 2, 1);
            // Mast guide rings (subtle horizontal ticks)
            cx.fillStyle = 'rgba(200,220,255,.1)';
            for (let ry = b.y + b.h * .55; ry < b.y + b.h * .9; ry += b.h * .12) {
              cx.fillRect(b.x + sx - .5, ry, b.w + 1, .8);
            }
            const tipX = b.x + b.w / 2 + sx, tipY = b.y;
            const pulse = .5 + Math.sin(now * .004) * .5;
            cx.beginPath(); cx.arc(tipX, tipY, 3, 0, 6.28);
            cx.fillStyle = `rgba(200,220,255,${.7 * pulse})`; cx.fill();
            cx.shadowColor = `rgba(180,200,255,${.8 * pulse})`; cx.shadowBlur = 20; cx.fill(); cx.shadowBlur = 0;
            if (Math.sin(now * .003) > .3) {
              cx.beginPath(); cx.arc(tipX, tipY + 15, 1.5, 0, 6.28);
              cx.fillStyle = 'rgba(244,63,94,.8)'; cx.fill();
            }
            continue;
          }
          if (b.sp === 'cn-sup') {
            // Flared support — narrow at bottom, widens into pod (the tapered neck)
            cx.fillStyle = 'rgba(255,255,255,.06)';
            cx.beginPath();
            cx.moveTo(b.x + sx + b.w*.32, b.y + b.h);
            cx.lineTo(b.x + sx + b.w*.68, b.y + b.h);
            cx.lineTo(b.x + sx + b.w, b.y);
            cx.lineTo(b.x + sx, b.y);
            cx.closePath();
            cx.fill();
            continue;
          }
          if (b.sp === 'cn-shaft') {
            // Tapered concrete shaft — much wider at base, narrows significantly going up
            const baseW = b.w * 1.8, topW = b.w * 0.55;
            const baseL = b.x + sx + (b.w - baseW)/2, baseR = baseL + baseW;
            const topL = b.x + sx + (b.w - topW)/2, topR = topL + topW;
            // Concrete body
            cx.fillStyle = 'rgba(230,225,215,.09)';
            cx.beginPath();
            cx.moveTo(baseL, b.y + b.h);
            cx.lineTo(baseR, b.y + b.h);
            cx.lineTo(topR, b.y);
            cx.lineTo(topL, b.y);
            cx.closePath();
            cx.fill();
            // Center highlight strip (Y-shaft geometry hint — lit side)
            cx.fillStyle = 'rgba(255,250,240,.06)';
            cx.beginPath();
            cx.moveTo(b.x + sx + b.w*.5 - baseW*.08, b.y + b.h);
            cx.lineTo(b.x + sx + b.w*.5 + baseW*.08, b.y + b.h);
            cx.lineTo(b.x + sx + b.w*.5 + topW*.08, b.y);
            cx.lineTo(b.x + sx + b.w*.5 - topW*.08, b.y);
            cx.closePath();
            cx.fill();
            // Subtle vertical edge lines (concrete ribs)
            cx.strokeStyle = 'rgba(255,255,255,.04)';
            cx.lineWidth = 1;
            cx.beginPath();
            cx.moveTo(b.x + sx + b.w*.5 - baseW*.25, b.y + b.h);
            cx.lineTo(b.x + sx + b.w*.5 - topW*.25, b.y);
            cx.moveTo(b.x + sx + b.w*.5 + baseW*.25, b.y + b.h);
            cx.lineTo(b.x + sx + b.w*.5 + topW*.25, b.y);
            cx.stroke();
            // Occasional pinpoint elevator lights (not grid windows)
            for (const win of b.wins) {
              if (win.ry < b.h * .15 || win.ry > b.h * .85) continue;
              if ((win.rx + win.ry) % 18 > 2) continue;
              const fl = .6 + Math.sin(now * .0015 + win.f) * .3;
              cx.fillStyle = `rgba(${win.r},${win.g},${win.b},${win.a * fl * .7})`;
              const taperT = win.ry / b.h;
              const lineW = baseW + (topW - baseW) * taperT;
              const lineL = b.x + sx + b.w*.5 - lineW/2;
              cx.fillRect(lineL + lineW*.5 - 1, b.y + win.ry, 1.5, 1.5);
            }
            continue;
          }
          // Building body with tint
          const bt = b.tint || [255,255,255];
          cx.fillStyle = `rgba(${bt[0]},${bt[1]},${bt[2]},${b.bodyAlpha || .05})`;
          cx.fillRect(b.x + sx, b.y, b.w, b.h);
          cx.strokeStyle = `rgba(${bt[0]},${bt[1]},${bt[2]},.04)`;
          cx.lineWidth = .5; cx.strokeRect(b.x + sx, b.y, b.w, b.h);
          // Roof edge
          cx.fillStyle = `rgba(${bt[0]},${bt[1]},${bt[2]},.06)`;
          cx.fillRect(b.x + sx, b.y, b.w, 1);
          // Bank tower colored tops (financial district — tall buildings)
          if(b.h > 150 && b.x > W*.45 && b.x < W*.75){
            const bankColors=[[0,100,0],[0,40,120],[180,0,0],[255,180,0]]; // TD green, RBC blue, Scotia red, CIBC gold
            const bc=bankColors[~~((b.x*7)%bankColors.length)];
            // Colored crown/spire light
            cx.fillStyle=`rgba(${bc[0]},${bc[1]},${bc[2]},.15)`;
            cx.fillRect(b.x+sx,b.y,b.w,4);
            cx.shadowColor=`rgba(${bc[0]},${bc[1]},${bc[2]},.2)`;cx.shadowBlur=8;
            cx.fillRect(b.x+sx+1,b.y+1,b.w-2,2);cx.shadowBlur=0;
          }
          for (const win of b.wins) { const fl = .75 + Math.sin(now * .0015 + win.f) * .25;
            cx.fillStyle = `rgba(${win.r},${win.g},${win.b},${win.a * fl})`;
            cx.fillRect(b.x + win.rx + sx, b.y + win.ry, win.w, win.h); }
          // ── Neon signs / billboards on mid-height buildings ──
          if(b.h > 80 && b.h < 200 && b.w > 15 && ((b.x*13)%17) > 11){
            const neonColors=[[255,0,80],[0,200,255],[255,200,0],[200,0,255],[0,255,150]];
            const nc=neonColors[~~((b.x*11)%neonColors.length)];
            const ny=b.y+b.h*.2, nw=b.w*.7, nh=4+((b.x*3)%4);
            cx.fillStyle=`rgba(${nc[0]},${nc[1]},${nc[2]},.12)`;
            cx.fillRect(b.x+sx+(b.w-nw)/2,ny,nw,nh);
            cx.shadowColor=`rgba(${nc[0]},${nc[1]},${nc[2]},.15)`;cx.shadowBlur=10;
            cx.fillRect(b.x+sx+(b.w-nw)/2+1,ny+1,nw-2,nh-2);cx.shadowBlur=0;
            // Second sign on some
            if(((b.x*7)%13)>8){
              const nc2=neonColors[~~((b.x*19)%neonColors.length)];
              const ny2=b.y+b.h*.5;
              cx.fillStyle=`rgba(${nc2[0]},${nc2[1]},${nc2[2]},.1)`;
              cx.fillRect(b.x+sx+2,ny2,b.w*.5,3);
              cx.shadowColor=`rgba(${nc2[0]},${nc2[1]},${nc2[2]},.12)`;cx.shadowBlur=6;
              cx.fillRect(b.x+sx+3,ny2,b.w*.5-2,2);cx.shadowBlur=0;
            }
          }

        } else if (b.db.length) {
          let gone = true;
          for (const d of b.db) {
            if (d.a <= 0) continue; gone = false;
            if (!d.sunk && !d.gn) {
              d.vy += GR; d.x += d.vx; d.y += d.vy; d.rot += d.rv; d.vx *= .99;
              if (d.y + d.h >= landY && !d.sunk) {
                // Hit the land
                d.y = landY - d.h; d.vy *= -.2; d.vx *= .7; d.rv *= .3;
                if (Math.abs(d.vy) < .5) d.gn = true;
              }
              if (d.y + d.h >= waterY) {
                // Sinking into water
                if (!d.sunk && d.vy > .5) splashes.push({ x: d.x, t: now, r: d.r, g: d.g, b: d.b });
                d.sunk = true; d.vy *= .1; d.vx *= .2; d.y += d.vy; d.a -= .02;
              }
            } else if (d.sunk) { d.y += .3; d.a -= .015; }
            if (now - b.dt > 2000 && !d.sunk) d.a -= .01;
            if (d.a > 0) { cx.save(); cx.translate(d.x + d.w / 2, d.y + d.h / 2); cx.rotate(d.rot);
              cx.fillStyle = `rgba(${d.r},${d.g},${d.b},${d.ba * d.a})`;
              cx.fillRect(-d.w / 2, -d.h / 2, d.w, d.h); cx.restore(); }
          }
          if (gone) { b.rb = true; b.rp = 0; b.db = []; }
        } else if (b.rb) {
          b.rp = Math.min(b.rp + RS, 1); const ease = 1 - Math.pow(1 - b.rp, 3);
          const cH = b.h * ease, dY = landY - cH;
          if (b.sp === 'cn-pod') {
            const t = now * .0003, i0 = ~~t % 3, i1 = (i0 + 1) % 3, bl = t % 1;
            const pr = C[i0][0]+(C[i1][0]-C[i0][0])*bl, pg = C[i0][1]+(C[i1][1]-C[i0][1])*bl, pb = C[i0][2]+(C[i1][2]-C[i0][2])*bl;
            cx.fillStyle = `rgba(${pr},${pg},${pb},${.15 * ease})`; cx.fillRect(b.x, dY, b.w, cH);
          } else if (b.sp === 'cn-upper' || b.sp === 'cn-sup') {
            cx.fillStyle = `rgba(255,255,255,${.05 * ease})`; cx.fillRect(b.x, dY, b.w, cH);
          } else if (b.sp === 'dome') {
            cx.fillStyle = `rgba(255,255,255,${.04 * ease})`; cx.beginPath();
            cx.moveTo(b.x, landY); cx.quadraticCurveTo(b.x + b.w * .5, dY - b.h * .3, b.x + b.w, landY); cx.fill();
          } else {
            const rbt = b.tint || [255,255,255];
            cx.fillStyle = `rgba(${rbt[0]},${rbt[1]},${rbt[2]},${(b.bodyAlpha||.05) * ease})`; cx.fillRect(b.x, dY, b.w, cH);
            for (const win of b.wins) { const aY = b.y + win.ry; if (aY >= dY) {
              const fl = .8 + Math.sin(now * .0015 + win.f) * .2;
              cx.fillStyle = `rgba(${win.r},${win.g},${win.b},${win.a * fl * ease})`;
              cx.fillRect(b.x + win.rx, aY, win.w, win.h); } }
          }
          if (b.rp >= 1) { b.ok = true; b.rb = false; }
        }
      }

      if (cnPodOk) drawPerson(cnPodX, cnPodY - 2, now);

      // ── Land strip with varied terrain ──
      const landH = waterY - landY;
      // Base ground
      const lg = cx.createLinearGradient(0, landY, 0, waterY);
      lg.addColorStop(0, 'rgba(25,22,18,.22)');
      lg.addColorStop(.4, 'rgba(20,18,15,.2)');
      lg.addColorStop(.8, 'rgba(30,25,15,.15)');
      lg.addColorStop(1, 'rgba(45,38,25,.12)');
      cx.fillStyle = lg; cx.fillRect(0, landY, W, landH);

      // Sandy beach patches (Sugar Beach / Sunnyside vibes)
      const beachZones = [[W * .08, W * .16], [W * .42, W * .52], [W * .78, W * .88]];
      for (const bz of beachZones) {
        const bg = cx.createLinearGradient(0, waterY - landH * .4, 0, waterY);
        bg.addColorStop(0, 'rgba(60,50,35,.06)');
        bg.addColorStop(.5, 'rgba(80,70,50,.1)');
        bg.addColorStop(1, 'rgba(100,90,65,.08)');
        cx.fillStyle = bg;
        cx.fillRect(bz[0], waterY - landH * .5, bz[1] - bz[0], landH * .5);
        // Sandy texture dots
        for (let si = 0; si < 8; si++) {
          const sx = bz[0] + Math.random() * (bz[1] - bz[0]);
          const sy = waterY - Math.random() * landH * .4;
          cx.fillStyle = 'rgba(120,105,75,.04)';
          cx.beginPath(); cx.arc(sx, sy, 1 + Math.random() * 2, 0, 6.28); cx.fill();
        }
      }

      // Ground edge
      cx.fillStyle = 'rgba(255,255,255,.015)'; cx.fillRect(0, landY, W, 1);
      // Shore gradient — sand meets water
      const shore = cx.createLinearGradient(0, waterY - 4, 0, waterY);
      shore.addColorStop(0, 'rgba(80,70,50,.06)');
      shore.addColorStop(1, 'rgba(40,50,60,.08)');
      cx.fillStyle = shore; cx.fillRect(0, waterY - 4, W, 4);

      // ── Waterfront park — grass strip with denser greenery ──
      const grassY = landY + 2;
      const grassH = (waterY - landY) * .55;
      const grassGrad = cx.createLinearGradient(0, grassY, 0, grassY + grassH);
      grassGrad.addColorStop(0,'rgba(40,75,35,.18)');
      grassGrad.addColorStop(.6,'rgba(35,65,30,.12)');
      grassGrad.addColorStop(1,'transparent');
      cx.fillStyle = grassGrad; cx.fillRect(0, grassY, W, grassH);
      // Grass blade texture — subtle vertical strokes
      cx.strokeStyle = 'rgba(60,110,45,.08)'; cx.lineWidth = .5;
      for(let gx=0; gx<W; gx+=4){
        const gh = 2 + Math.sin(gx*.7) * 1.2;
        cx.beginPath(); cx.moveTo(gx, grassY); cx.lineTo(gx, grassY + gh); cx.stroke();
      }
      // Winding park path (light gravel)
      cx.strokeStyle = 'rgba(180,165,135,.1)'; cx.lineWidth = 3;
      cx.beginPath();
      for(let px=0; px<W; px+=8){
        const py = grassY + grassH*.55 + Math.sin(px*.008)*6;
        px===0?cx.moveTo(px,py):cx.lineTo(px,py);
      }
      cx.stroke();

      // ── Streetlights, trees, benches, bushes ──
      for(const pk of parkItems){
        if(pk.type==='light') drawStreetlight(pk.x,landY+2,now);
        else if(pk.type==='bench') drawBench(pk.x,landY+8);
        else if(pk.type==='bush') drawBush(pk.x,landY+6,pk.size*.7);
        else drawTree(pk.x,landY+2,pk.size,now,pk.nearLight);
      }

      // ── Water ──
      const wg = cx.createLinearGradient(0, waterY, 0, H);
      wg.addColorStop(0, 'rgba(8,12,25,.25)'); wg.addColorStop(.3, 'rgba(5,8,20,.35)'); wg.addColorStop(1, 'rgba(3,5,15,.5)');
      cx.fillStyle = wg; cx.fillRect(0, waterY, W, H - waterY);
      cx.fillStyle = 'rgba(255,255,255,.02)'; cx.fillRect(0, waterY, W, 1);

      // ── Skyline reflection glow on water ──
      for(const b of blds){
        if(!b.ok||b.sp)continue;
        const rc=b.tint||[255,255,255];
        const rh=Math.min(b.h*.3,H-waterY);
        const rg2=cx.createLinearGradient(0,waterY,0,waterY+rh);
        rg2.addColorStop(0,`rgba(${rc[0]},${rc[1]},${rc[2]},.04)`);rg2.addColorStop(1,'transparent');
        cx.fillStyle=rg2;
        const wv=Math.sin(now*.001+b.x*.01)*2;
        cx.fillRect(b.x+wv,waterY+1,b.w,rh);
      }

      // Reflections
      for (const b of blds) {
        if (!b.ok || b.sp === 'dome') continue;
        const bcx = b.x + b.w / 2, ci = ~~((bcx / W) * 3) % 3, c = C[ci];
        const reflH = Math.min(b.h * .5, H - waterY), reflW = b.w * .6;
        const rg = cx.createLinearGradient(0, waterY, 0, waterY + reflH);
        rg.addColorStop(0, `rgba(${c[0]},${c[1]},${c[2]},.06)`); rg.addColorStop(1, 'transparent');
        cx.fillStyle = rg;
        cx.fillRect(bcx - reflW / 2 + Math.sin(now * .001 + bcx * .01) * 2, waterY + 2, reflW, reflH);
      }

      // Splash ripples
      for (let i = splashes.length - 1; i >= 0; i--) {
        const sp = splashes[i], age = (now - sp.t) / 1000;
        if (age > 1.5) { splashes.splice(i, 1); continue; }
        cx.beginPath(); cx.arc(sp.x, waterY, age * 25, 0, 6.28);
        cx.strokeStyle = `rgba(${sp.r},${sp.g},${sp.b},${.2 * (1 - age / 1.5)})`;
        cx.lineWidth = 1; cx.stroke();
      }

      // ── "TORONTO" sign — sitting on the waterfront (Nathan Phillips style) ──
      const signFont = Math.max(16, W*.018);
      cx.font = `900 ${signFont}px Inter,sans-serif`;
      const letters = 'TORONTO';
      const charW = signFont * .85;
      const totalW = letters.length * charW + charW; // extra slot for maple leaf
      const signX = W*.5 - totalW/2;
      const signY = landY + (waterY - landY) * .35;
      // Dark base platform behind letters
      cx.fillStyle = 'rgba(15,15,20,.5)';
      cx.fillRect(signX - 6, signY - signFont*.85, totalW + 12, signFont * 1.05);
      cx.strokeStyle = 'rgba(80,80,90,.4)'; cx.lineWidth = .8;
      cx.strokeRect(signX - 6, signY - signFont*.85, totalW + 12, signFont * 1.05);
      // Illuminated letters
      for(let li=0; li<letters.length; li++){
        const lx = signX + li*charW;
        const lc = C[li%3];
        cx.shadowColor = `rgba(${lc[0]},${lc[1]},${lc[2]},.7)`; cx.shadowBlur = 14;
        cx.fillStyle = `rgba(${lc[0]},${lc[1]},${lc[2]},.85)`;
        cx.fillText(letters[li], lx, signY);
        cx.shadowBlur = 0;
        cx.fillStyle = 'rgba(255,255,255,.3)';
        cx.fillText(letters[li], lx, signY);
      }
      // Maple leaf — to the right of the last O
      const lcx = signX + letters.length*charW + charW*.5;
      const lcy = signY - signFont*.4;
      const lsz = signFont * .58;
      cx.shadowColor = 'rgba(255,40,40,.85)'; cx.shadowBlur = 16;
      cx.fillStyle = 'rgba(230,30,40,.95)';
      cx.beginPath();
      const pts = [
        [0,-1.0],[.18,-.55],[.5,-.6],[.38,-.3],[.7,-.05],
        [.5,.05],[.55,.35],[.22,.25],[.18,.55],[0,.4],
        [-.18,.55],[-.22,.25],[-.55,.35],[-.5,.05],[-.7,-.05],
        [-.38,-.3],[-.5,-.6],[-.18,-.55]
      ];
      cx.moveTo(lcx + pts[0][0]*lsz, lcy + pts[0][1]*lsz);
      for(let pi=1; pi<pts.length; pi++){
        cx.lineTo(lcx + pts[pi][0]*lsz, lcy + pts[pi][1]*lsz);
      }
      cx.closePath(); cx.fill();
      cx.shadowBlur = 0;
      cx.fillStyle = 'rgba(255,255,255,.25)';
      cx.beginPath();
      cx.moveTo(lcx + pts[0][0]*lsz*.6, lcy + pts[0][1]*lsz*.6);
      for(let pi=1; pi<pts.length; pi++){
        cx.lineTo(lcx + pts[pi][0]*lsz*.6, lcy + pts[pi][1]*lsz*.6);
      }
      cx.closePath(); cx.fill();
      // Glow pool on ground beneath
      const sgGlow = cx.createRadialGradient(W*.5, signY+4, 0, W*.5, signY+4, totalW*.7);
      sgGlow.addColorStop(0,'rgba(200,180,255,.06)');
      sgGlow.addColorStop(1,'transparent');
      cx.fillStyle = sgGlow;
      cx.fillRect(W*.5 - totalW, signY-4, totalW*2, 30);

      // ── Animated construction cranes ──
      for(const cr of cranes){
        const cBase=cr.x, cH=cr.h;
        // Boom rotation — slow swing (each crane unique)
        cr.armPhase += cr.armSpeed;
        const armA = Math.sin(cr.armPhase) * .35; // rotation angle (radians)
        const cosA = Math.cos(armA), sinA = Math.sin(armA);
        const tipX = cBase + cosA * cr.boomLen;
        const tipY = (landY - cH) + sinA * cr.boomLen;
        const backX = cBase - cosA * 18;
        const backY = (landY - cH) - sinA * 18;
        // Tower
        cx.strokeStyle='rgba(255,200,50,.18)';cx.lineWidth=1.8;
        cx.beginPath();cx.moveTo(cBase,landY);cx.lineTo(cBase,landY-cH);cx.stroke();
        // Tower lattice
        cx.strokeStyle='rgba(255,200,50,.08)';cx.lineWidth=.5;
        for(let lv=landY-cH+10;lv<landY-5;lv+=14){
          cx.beginPath();cx.moveTo(cBase-2,lv);cx.lineTo(cBase+2,lv+7);cx.stroke();
          cx.beginPath();cx.moveTo(cBase+2,lv);cx.lineTo(cBase-2,lv+7);cx.stroke();
        }
        // Boom + counter-jib (rotating)
        cx.strokeStyle='rgba(255,200,50,.18)';cx.lineWidth=1.5;
        cx.beginPath();cx.moveTo(backX,backY);cx.lineTo(tipX,tipY);cx.stroke();
        // Support cables (A-frame on top)
        cx.strokeStyle='rgba(255,200,50,.1)';cx.lineWidth=.5;
        cx.beginPath();cx.moveTo(cBase,landY-cH-8);cx.lineTo(tipX,tipY);cx.stroke();
        cx.beginPath();cx.moveTo(cBase,landY-cH-8);cx.lineTo(backX,backY);cx.stroke();
        cx.beginPath();cx.moveTo(cBase,landY-cH);cx.lineTo(cBase,landY-cH-8);cx.stroke();
        // Hook + cargo (lifts/lowers)
        cr.hookPhase += cr.hookSpeed;
        const hookY = tipY + 8 + (Math.sin(cr.hookPhase) * .5 + .5) * 35;
        cx.strokeStyle='rgba(255,200,50,.12)';cx.lineWidth=.6;
        cx.beginPath();cx.moveTo(tipX,tipY);cx.lineTo(tipX,hookY);cx.stroke();
        if(cr.cargoOn){
          cx.fillStyle='rgba(180,140,80,.3)';
          cx.fillRect(tipX-3,hookY,6,4);
        } else {
          cx.fillStyle='rgba(200,200,200,.25)';
          cx.fillRect(tipX-1.5,hookY,3,2);
        }
        // Operator cab on tower
        cx.fillStyle='rgba(255,210,80,.18)';
        cx.fillRect(cBase-3,landY-cH+3,6,5);
        // Blinking warning light at top
        if(Math.sin(now*.004+cr.blinkOff)>.2){
          cx.beginPath();cx.arc(cBase,landY-cH-10,2.5,0,6.28);
          cx.fillStyle='rgba(255,50,30,.75)';cx.fill();
          cx.shadowColor='rgba(255,50,30,.5)';cx.shadowBlur=10;cx.fill();cx.shadowBlur=0;
        }
        // Tip nav light
        cx.beginPath();cx.arc(tipX,tipY,1.2,0,6.28);
        cx.fillStyle='rgba(255,255,200,.6)';cx.fill();
      }

      // ── Helicopters with searchlights ──
      for(const h of helis){
        h.x += h.vx;
        if(h.x>W+40)h.x=-40; if(h.x<-40)h.x=W+40;
        h.rotor += .8;
        h.searchPhase += .02;
        const hx=h.x, hy=h.y, dir=h.vx>0?1:-1;
        // Body
        cx.fillStyle='rgba(60,65,75,.55)';
        cx.beginPath();cx.ellipse(hx,hy,7,3,0,0,6.28);cx.fill();
        // Tail boom
        cx.fillRect(hx-9*dir,hy-1,9,2);
        // Tail rotor
        const tr=Math.sin(h.rotor*1.5)*3;
        cx.strokeStyle='rgba(180,180,180,.35)';cx.lineWidth=.6;
        cx.beginPath();cx.moveTo(hx-9*dir,hy-tr);cx.lineTo(hx-9*dir,hy+tr);cx.stroke();
        // Main rotor blur
        cx.strokeStyle='rgba(200,200,210,.25)';cx.lineWidth=1;
        cx.beginPath();cx.moveTo(hx-12,hy-3);cx.lineTo(hx+12,hy-3);cx.stroke();
        // Blinking nav lights
        const blink=Math.sin(now*.008)>0;
        cx.beginPath();cx.arc(hx-5*dir,hy+2,1.2,0,6.28);
        cx.fillStyle=blink?'rgba(255,30,30,.9)':'rgba(255,30,30,.3)';cx.fill();
        cx.beginPath();cx.arc(hx+5*dir,hy+2,1.2,0,6.28);
        cx.fillStyle=blink?'rgba(30,255,80,.3)':'rgba(30,255,80,.9)';cx.fill();
        // Searchlight cone — sweeps as it flies
        const sweep=Math.sin(h.searchPhase)*.4;
        const slAng=Math.PI/2 + sweep;
        const slLen=120;
        const slEx=hx+Math.cos(slAng)*slLen;
        const slEy=hy+Math.sin(slAng)*slLen;
        const slGrad=cx.createLinearGradient(hx,hy+2,slEx,slEy);
        slGrad.addColorStop(0,'rgba(255,240,180,.2)');
        slGrad.addColorStop(1,'transparent');
        cx.fillStyle=slGrad;
        cx.beginPath();cx.moveTo(hx,hy+2);
        cx.lineTo(hx+Math.cos(slAng-.12)*slLen, hy+Math.sin(slAng-.12)*slLen);
        cx.lineTo(hx+Math.cos(slAng+.12)*slLen, hy+Math.sin(slAng+.12)*slLen);
        cx.closePath();cx.fill();
      }

      // ── High-altitude plane with nav lights ──
      for(const p of planes){
        p.x += p.vx;
        if(p.x>W+100)p.x=-100;
        if(p.x<-100)p.x=W+100;
        const px=p.x, py=p.y, dir=p.vx>0?1:-1;
        // Fuselage
        cx.fillStyle='rgba(180,190,200,.4)';
        cx.beginPath();cx.ellipse(px,py,8,1.5,0,0,6.28);cx.fill();
        // Wings
        cx.fillRect(px-2,py-.5,4,4);
        cx.fillRect(px-1,py-3,2,3);
        // Contrail (always trails behind)
        const ctStart=px-60*dir;
        const ctGrad=cx.createLinearGradient(ctStart,py,px,py);
        ctGrad.addColorStop(0,'transparent');
        ctGrad.addColorStop(1,'rgba(255,255,255,.15)');
        cx.fillStyle=ctGrad;
        cx.fillRect(Math.min(ctStart,px),py-.5,60,1);
        // Blinking nav light at the front
        if(Math.sin(now*.006)>.5){
          cx.beginPath();cx.arc(px+6*dir,py,1,0,6.28);
          cx.fillStyle='rgba(255,80,80,.9)';cx.fill();
          cx.shadowColor='rgba(255,50,50,.5)';cx.shadowBlur=6;cx.fill();cx.shadowBlur=0;
        }
      }

      // ── TTC Streetcar ──
      const scX=(now*.04)%(W+60)-30;
      const scY=landY-2;
      cx.fillStyle='rgba(200,30,30,.3)';cx.fillRect(scX-15,scY-8,30,8);
      cx.fillStyle='rgba(180,20,20,.2)';cx.fillRect(scX-14,scY-9,28,2); // roof
      for(let sw=scX-12;sw<scX+12;sw+=4){
        cx.fillStyle='rgba(255,230,150,.35)';cx.fillRect(sw,scY-7,3,4);
      }
      cx.strokeStyle='rgba(200,200,200,.15)';cx.lineWidth=.8;
      cx.beginPath();cx.moveTo(scX,scY-9);cx.lineTo(scX-2,scY-14);cx.lineTo(scX+2,scY-14);cx.stroke();
      cx.beginPath();cx.arc(scX+15,scY-4,1.5,0,6.28);
      cx.fillStyle='rgba(255,220,150,.5)';cx.fill();
      cx.shadowColor='rgba(255,220,150,.3)';cx.shadowBlur=6;cx.fill();cx.shadowBlur=0;

      // ── Ferry on the harbor (no island line) ──
      const ferryX=(W*.15+(now*.02)%(W*.7));
      const ferryY=waterY+(H-waterY)*.3;
      cx.fillStyle='rgba(200,210,220,.15)';
      cx.fillRect(ferryX-15,ferryY-5,30,8);
      cx.fillStyle='rgba(180,190,200,.12)';cx.fillRect(ferryX-12,ferryY-8,24,4);
      cx.fillStyle='rgba(255,220,150,.4)';
      for(let fl=ferryX-10;fl<ferryX+10;fl+=4){cx.fillRect(fl,ferryY-7,2.5,2.5);}
      cx.strokeStyle='rgba(255,255,255,.04)';cx.lineWidth=.5;
      cx.beginPath();cx.moveTo(ferryX-15,ferryY);cx.lineTo(ferryX-35,ferryY+5);cx.stroke();

      // ── Harbor boats with lights ──
      for(const bt of boats){
        bt.x+=bt.sp;bt.bob+=.03;
        if(bt.x>W+30)bt.x=-25;if(bt.x<-30)bt.x=W+25;
        const by=bt.y+Math.sin(bt.bob)*1.5;

        if(bt.big){
          // Cruise/tour boat — bigger, more lit
          cx.fillStyle='rgba(200,200,210,.08)';
          cx.beginPath();cx.moveTo(bt.x-bt.sz,by);cx.quadraticCurveTo(bt.x,by+bt.sz*.25,bt.x+bt.sz,by);ctx.fill?0:0;cx.fill();
          cx.fillStyle='rgba(180,185,195,.06)';cx.fillRect(bt.x-bt.sz*.7,by-6,bt.sz*1.4,6);
          cx.fillStyle='rgba(160,170,180,.05)';cx.fillRect(bt.x-bt.sz*.5,by-10,bt.sz,4);
          // Row of windows
          cx.fillStyle='rgba(255,220,150,.3)';
          for(let wl=bt.x-bt.sz*.6;wl<bt.x+bt.sz*.6;wl+=4){cx.fillRect(wl,by-5,2,3);}
          cx.fillStyle='rgba(255,220,150,.2)';
          for(let wl=bt.x-bt.sz*.4;wl<bt.x+bt.sz*.4;wl+=4){cx.fillRect(wl,by-9,2,2);}
          // Colored reflection
          for(let ri=0;ri<3;ri++){
            cx.fillStyle=`rgba(${C[ri][0]},${C[ri][1]},${C[ri][2]},.03)`;
            cx.fillRect(bt.x-bt.sz*.3+ri*8,by+4,4,12);}
        } else {
          // Regular small boat
          cx.fillStyle='rgba(255,255,255,.05)';
          cx.beginPath();cx.moveTo(bt.x-bt.sz,by);cx.quadraticCurveTo(bt.x,by+bt.sz*.3,bt.x+bt.sz,by);cx.fill();
          cx.beginPath();cx.arc(bt.x,by-1,1.5,0,6.28);
          cx.fillStyle=`rgba(${bt.c[0]},${bt.c[1]},${bt.c[2]},.35)`;cx.fill();
          cx.shadowColor=`rgba(${bt.c[0]},${bt.c[1]},${bt.c[2]},.25)`;cx.shadowBlur=6;cx.fill();cx.shadowBlur=0;
          cx.fillStyle=`rgba(${bt.c[0]},${bt.c[1]},${bt.c[2]},.05)`;
          cx.fillRect(bt.x-1,by+2,2,10+Math.sin(bt.bob)*3);
        }
      }

      // ── Cars on Gardiner Expressway ──
      const carY=landY-2;
      // Road surface
      cx.fillStyle='rgba(40,40,45,.15)';cx.fillRect(0,carY-4,W,7);
      cx.fillStyle='rgba(255,255,100,.02)';cx.fillRect(0,carY-.5,W,1); // center line
      // Lane dividers
      for(let lx=0;lx<W;lx+=20){cx.fillStyle='rgba(255,255,255,.03)';cx.fillRect(lx,carY-2,10,.5);}

      for(const cr of cars){
        cr.x+=cr.sp*cr.dir;
        if(cr.x>W+30)cr.x=-30;if(cr.x<-30)cr.x=W+30;
        const facing=cr.dir;

        if(cr.type==='semi'){
          // Semi truck — long box
          cx.fillStyle='rgba(200,200,210,.12)';cx.fillRect(cr.x-12*facing,carY-4,12,5); // trailer
          cx.fillStyle='rgba(180,180,190,.15)';cx.fillRect(cr.x,carY-3.5,5*facing,4); // cab
          // Headlights
          cx.fillStyle=facing>0?'rgba(255,220,150,.5)':'rgba(255,50,30,.5)';
          cx.beginPath();cx.arc(cr.x+5*facing,carY-1.5,1.5,0,6.28);cx.fill();
          cx.shadowColor=facing>0?'rgba(255,220,150,.3)':'rgba(255,50,30,.3)';cx.shadowBlur=8;cx.fill();cx.shadowBlur=0;
        } else if(cr.type==='suv'){
          // SUV — taller box
          cx.fillStyle='rgba(160,160,170,.12)';cx.fillRect(cr.x-4*facing,carY-4.5,8,5.5);
          // Headlights
          cx.fillStyle=facing>0?'rgba(255,220,150,.5)':'rgba(255,50,30,.5)';
          cx.beginPath();cx.arc(cr.x+4*facing,carY-2,1.3,0,6.28);cx.fill();
          cx.shadowColor=facing>0?'rgba(255,220,150,.2)':'rgba(255,50,30,.2)';cx.shadowBlur=6;cx.fill();cx.shadowBlur=0;
        } else if(cr.type==='cop'){
          // Cop car — with siren
          cr.siren+=.15;
          cx.fillStyle='rgba(40,40,50,.15)';cx.fillRect(cr.x-3.5*facing,carY-3.5,7,4);
          // Siren lights — alternating red/blue
          const s1=Math.sin(cr.siren*8)>.0,s2=!s1;
          if(s1){cx.fillStyle='rgba(255,30,30,.6)';cx.beginPath();cx.arc(cr.x-1,carY-4,1.2,0,6.28);cx.fill();
            cx.shadowColor='rgba(255,30,30,.4)';cx.shadowBlur=10;cx.fill();cx.shadowBlur=0;}
          if(s2){cx.fillStyle='rgba(30,80,255,.6)';cx.beginPath();cx.arc(cr.x+1,carY-4,1.2,0,6.28);cx.fill();
            cx.shadowColor='rgba(30,80,255,.4)';cx.shadowBlur=10;cx.fill();cx.shadowBlur=0;}
          // Headlights
          cx.fillStyle=facing>0?'rgba(255,220,150,.4)':'rgba(255,50,30,.4)';
          cx.beginPath();cx.arc(cr.x+3.5*facing,carY-1.5,1,0,6.28);cx.fill();
        } else {
          // Sedan
          cx.fillStyle='rgba(150,150,160,.1)';cx.fillRect(cr.x-3*facing,carY-3,6,3.5);
          // Headlights
          cx.fillStyle=facing>0?'rgba(255,220,150,.45)':'rgba(255,50,30,.45)';
          cx.beginPath();cx.arc(cr.x+3*facing,carY-1.5,1,0,6.28);cx.fill();
          cx.shadowColor=facing>0?'rgba(255,220,150,.2)':'rgba(255,50,30,.2)';cx.shadowBlur=5;cx.fill();cx.shadowBlur=0;
        }
        // Light trail on road
        cx.fillStyle=`rgba(${cr.c[0]},${cr.c[1]},${cr.c[2]},.06)`;
        cx.fillRect(cr.x-cr.dir*12,carY-1.5,cr.dir*12,1);
      }

      // ── Occasional fireworks ──
      if(Math.random()<.002) fireworks.push({x:W*.3+Math.random()*W*.4,y:landY*.5+Math.random()*landY*.2,t:now,c:C[~~(Math.random()*3)],particles:[]});
      for(let i=fireworks.length-1;i>=0;i--){
        const fw=fireworks[i],age=(now-fw.t)/1000;
        if(age>2.5){fireworks.splice(i,1);continue;}
        if(fw.particles.length===0&&age>.01){
          for(let p=0;p<30;p++){const a=Math.random()*6.28,sp=1+Math.random()*3;
            fw.particles.push({x:fw.x,y:fw.y,vx:Math.cos(a)*sp,vy:Math.sin(a)*sp});}
        }
        for(const p of fw.particles){
          p.x+=p.vx;p.y+=p.vy;p.vy+=.03;p.vx*=.98;p.vy*=.98;
          const pa=Math.max(0,1-age/2.5);
          cx.beginPath();cx.arc(p.x,p.y,1,0,6.28);
          cx.fillStyle=`rgba(${fw.c[0]},${fw.c[1]},${fw.c[2]},${.4*pa})`;cx.fill();
        }
      }
    }

    // Desktop mouse
    document.addEventListener('mousemove', (e) => { ms.x = e.clientX; ms.y = e.clientY; });
    document.addEventListener('mouseleave', () => { ms.x = -9e3; ms.y = -9e3; });

    // Mobile touch — deliberate drag to destroy, not accidental scroll
    if (isMob) {
      let touchStartY = 0, touchStartX = 0, scrolling = false;
      document.addEventListener('touchstart', (e) => {
        if (e.touches.length === 1) {
          const t = e.touches[0];
          touchStartX = t.clientX; touchStartY = t.clientY;
          touchActive = false; scrolling = false;
        }
      }, { passive: true });

      document.addEventListener('touchmove', (e) => {
        if (e.touches.length !== 1) return;
        const t = e.touches[0];
        const dx = Math.abs(t.clientX - touchStartX);
        const dy = Math.abs(t.clientY - touchStartY);

        // If mostly vertical movement, it's a scroll — don't destroy
        if (!touchActive && dy > 15 && dy > dx * 1.5) { scrolling = true; }
        // If mostly horizontal or stayed in place, it's a deliberate swipe — destroy
        if (!scrolling && (dx > 8 || dy < 10)) { touchActive = true; }

        if (touchActive) {
          ms.x = t.clientX; ms.y = t.clientY;
        }
      }, { passive: true });

      document.addEventListener('touchend', () => {
        ms.x = -9e3; ms.y = -9e3;
        touchActive = false; scrolling = false;
      }, { passive: true });
    }

    window.addEventListener('scroll', () => {
      // Keep canvas faintly alive throughout the page (min .35) so it never freezes
      const fade = Math.max(1 - window.scrollY / (H * 1.2), 0);
      sOp = .35 + fade * .65;
      cv.style.opacity = String(sOp);
    }, { passive: true });
    window.addEventListener('resize', rsz);
    rsz(); requestAnimationFrame(frame);
  }

  // ═══════ SOCAL SCENE + THEME TOGGLE ═══════
  let isDark = true;
  const cv2 = document.querySelector('.city-canvas');
  let socalClouds=[], socalPalms=[], socalBirds=[], socalBoats=[], socalMansions=[];
  let socalRipples=[], socalDolphins=[], socalWaveOff=0;
  let socalHomes=[], socalDowntown=[];
  let socalJetSkis=[], socalSurfers=[], socalParaglider=null, socalBannerPlane=null;
  let socalNextAutoDolphin=0;
  const sMs = { x: -9e3, y: -9e3 }; // SoCal mouse separate tracking

  function genSocal() {
    if (!cv2) return;
    const W2=window.innerWidth, H2=window.innerHeight;
    socalClouds=[];
    for(let i=0;i<6;i++) socalClouds.push({x:Math.random()*W2*1.5-W2*.25,y:H2*.04+Math.random()*H2*.14,w:50+Math.random()*120,h:15+Math.random()*25,sp:.1+Math.random()*.3});
    socalPalms=[];
    const pc=W2<768?10:22;
    for(let i=0;i<pc;i++) socalPalms.push({x:(i/pc)*W2*.92+Math.random()*(W2/pc)*.3+W2*.02,h:35+Math.random()*50,lean:(Math.random()-.4)*.25,phase:Math.random()*6.28});
    socalBirds=[];
    for(let i=0;i<7;i++) socalBirds.push({x:Math.random()*W2,y:H2*.05+Math.random()*H2*.15,vx:.2+Math.random()*.6,vy:(Math.random()-.5)*.1,wing:Math.random()*6.28});
    // Two larger sailboats, positioned away from the pier (pier sits roughly W*.42–.62)
    socalBoats=[
      {x:W2*.12,y:H2*.83,sz:26,sp:.05,bob:0},
      {x:W2*.78,y:H2*.86,sz:24,sp:.04,bob:2.5}
    ];
    socalMansions=[];
    for(let i=0;i<7;i++){const mx=W2*.06+i*W2*.12;socalMansions.push({x:mx,w:14+(i*7%8),h:9+(i*5%6)});}
    socalHomes=[];
    socalDowntown=[]; // not used — replaced with pier + bluffs
    socalRipples=[]; socalDolphins=[];

    // Jet skis removed
    socalJetSkis=[];

    // Surfers removed
    socalSurfers=[];

    // Paraglider drifting over the cliffs
    socalParaglider={x:W2*.6,y:H2*.18,vx:.15,phase:Math.random()*6.28};

    // Banner plane crossing low across the beach
    socalBannerPlane={x:-300,y:H2*.16,vx:.7,bannerText:'SEAN KANI — BUILDER OF THINGS'};

    socalNextAutoDolphin=performance.now()+3000+Math.random()*5000;
  }

  function drawSocal(now) {
    if (!cv2) return;
    const ctx=cv2.getContext('2d');
    const W2=window.innerWidth,H2=window.innerHeight;
    const hillY=H2*.48,shoreY=H2*.68,waterStart=H2*.78;
    ctx.clearRect(0,0,W2,H2);

    // ── Sky ──
    const sky=ctx.createLinearGradient(0,0,0,waterStart);
    sky.addColorStop(0,'rgba(45,115,210,.55)');sky.addColorStop(.3,'rgba(75,145,218,.45)');
    sky.addColorStop(.6,'rgba(125,175,225,.32)');sky.addColorStop(.85,'rgba(195,190,175,.2)');
    sky.addColorStop(1,'rgba(225,210,170,.12)');
    ctx.fillStyle=sky;ctx.fillRect(0,0,W2,waterStart);

    // ── Sun ──
    const sunX=W2*.2,sunY=H2*.08,sunR=30;
    const sb=ctx.createRadialGradient(sunX,sunY,0,sunX,sunY,sunR*14);
    sb.addColorStop(0,'rgba(255,200,80,.12)');sb.addColorStop(.1,'rgba(255,180,60,.05)');sb.addColorStop(.3,'rgba(255,160,40,.02)');sb.addColorStop(1,'transparent');
    ctx.fillStyle=sb;ctx.fillRect(0,0,W2,H2);
    ctx.beginPath();ctx.arc(sunX,sunY,sunR,0,6.28);ctx.fillStyle='rgba(255,230,150,.6)';ctx.fill();
    ctx.shadowColor='rgba(255,200,80,.5)';ctx.shadowBlur=50;
    ctx.beginPath();ctx.arc(sunX,sunY,sunR*.6,0,6.28);ctx.fillStyle='rgba(255,240,180,.7)';ctx.fill();ctx.shadowBlur=0;

    // ── Clouds ──
    for(const cl of socalClouds){
      cl.x+=cl.sp;if(cl.x>W2+120)cl.x=-cl.w-60;
      for(let ci=0;ci<5;ci++){const cx2=cl.x+ci*cl.w*.22,cy=cl.y+Math.sin(ci*1.3)*cl.h*.15,cr=cl.h*(.5+Math.sin(ci*1.8)*.2);
        ctx.beginPath();ctx.arc(cx2,cy,cr,0,6.28);ctx.fillStyle='rgba(255,255,255,.35)';ctx.fill();}
    }

    // ── Birds ──
    for(const bd of socalBirds){
      bd.x+=bd.vx;bd.y+=bd.vy+Math.sin(now*.001+bd.wing)*.05;if(bd.x>W2+20)bd.x=-20;bd.wing+=.08;
      const w=Math.sin(bd.wing)*4;
      ctx.strokeStyle='rgba(40,30,20,.35)';ctx.lineWidth=1.5;
      ctx.beginPath();ctx.moveTo(bd.x-6,bd.y+w);ctx.quadraticCurveTo(bd.x,bd.y-2,bd.x+6,bd.y+w);ctx.stroke();
    }

    // ── Hills — 5 layers, filling left to right with depth ──
    // Far back (tallest, lightest)
    const hFn=(x,a,b,c)=>hillY-a*Math.sin(x*.0025)-b*Math.sin(x*.007)-c*Math.cos(x*.0015);
    ctx.fillStyle='rgba(50,88,38,.2)';
    ctx.beginPath();ctx.moveTo(0,shoreY);
    for(let x=0;x<W2;x+=6){ctx.lineTo(x,hFn(x,35,22,15)-25);}
    ctx.lineTo(W2,shoreY);ctx.fill();
    // Mid-back
    ctx.fillStyle='rgba(62,108,48,.18)';
    ctx.beginPath();ctx.moveTo(0,shoreY);
    for(let x=0;x<W2;x+=6){ctx.lineTo(x,hFn(x,28,16,12)-10);}
    ctx.lineTo(W2,shoreY);ctx.fill();
    // Mid — where mansions sit
    ctx.fillStyle='rgba(78,128,55,.16)';
    ctx.beginPath();ctx.moveTo(0,shoreY);
    for(let x=0;x<W2;x+=6){ctx.lineTo(x,hFn(x,22,12,8));}
    ctx.lineTo(W2,shoreY);ctx.fill();
    // Mid-front — lower hills closer to shore
    ctx.fillStyle='rgba(95,148,62,.13)';
    ctx.beginPath();ctx.moveTo(0,shoreY);
    for(let x=0;x<W2;x+=6){ctx.lineTo(x,hillY+15-Math.sin(x*.005)*15-Math.sin(x*.012)*8);}
    ctx.lineTo(W2,shoreY);ctx.fill();
    // Front — coastal bluff area on right
    ctx.fillStyle='rgba(110,160,68,.1)';
    ctx.beginPath();ctx.moveTo(0,shoreY);
