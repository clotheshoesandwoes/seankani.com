    ctx.beginPath();ctx.moveTo(0,roadFn2(0));
    for(let x=0;x<W2;x+=5){ctx.lineTo(x,roadFn2(x));}
    ctx.stroke();
    ctx.strokeStyle='rgba(255,230,80,.03)';ctx.lineWidth=.5;
    ctx.beginPath();ctx.moveTo(0,roadFn2(0));
    for(let x=0;x<W2;x+=5){ctx.lineTo(x,roadFn2(x));}
    ctx.stroke();
    // Cars on both roads — visible
    const carT=now*.0002;
    for(let ci=0;ci<10;ci++){
      const onRoad1=ci<5;
      const rd=onRoad1?roadFn1:roadFn2;
      const spd=onRoad1?.8:.6;
      const dir=ci%2===0?1:-1;
