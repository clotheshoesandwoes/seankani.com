    // ── Torrey Pines bluffs (right side) — vegetation follows the cliff ──
    const bluffPts=[];
    ctx.fillStyle='rgba(155,130,90,.22)';
    ctx.beginPath();ctx.moveTo(W2*.72,shoreY);
    for(let bx=W2*.72;bx<=W2;bx+=8){
      const by=shoreY-15-Math.sin((bx-W2*.72)*.015)*20-Math.cos((bx-W2*.72)*.025)*12;
      ctx.lineTo(bx,by);bluffPts.push({x:bx,y:by});
    }
    ctx.lineTo(W2,shoreY);ctx.fill();
    // Lighter face
    ctx.fillStyle='rgba(130,108,72,.15)';
    ctx.beginPath();ctx.moveTo(W2*.74,shoreY);
    for(const p of bluffPts){ctx.lineTo(p.x+3,p.y+6);}
    ctx.lineTo(W2,shoreY);ctx.fill();
    // Vegetation ON the cliff contour
    for(const p of bluffPts){
      if(Math.sin(p.x*.1)>.3){
        ctx.beginPath();ctx.arc(p.x,p.y-4,3+Math.sin(p.x*.2),0,6.28);
        ctx.fillStyle='rgba(55,100,42,.12)';ctx.fill();
      }
    }

    // ── SD beachfront — dense, clustered buildings like PB/OB ──
    for(let bx=W2*.02;bx<W2*.7;bx+=W2*.032){
