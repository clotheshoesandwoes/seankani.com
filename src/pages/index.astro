      ctx.fillStyle=`rgba(${js.c[0]},${js.c[1]},${js.c[2]},.7)`;
      ctx.beginPath();ctx.ellipse(js.x,jy,7,2.2,0,0,6.28);ctx.fill();
      // Rider
      ctx.fillStyle='rgba(40,30,20,.55)';
      ctx.fillRect(js.x-1,jy-5,2,4);
      ctx.beginPath();ctx.arc(js.x,jy-6,1.4,0,6.28);ctx.fill();
      // Spray
